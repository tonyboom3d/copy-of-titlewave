function formatMMDDYY_HHMMSS(value) {
    if (!value) return ''
    const d = new Date(value)
    if (isNaN(d.getTime())) return ''
    const mm = String(d.getMonth() + 1).padStart(2, '0')
    const dd = String(d.getDate()).padStart(2, '0')
    const yy = String(d.getFullYear()).slice(-2)
    const hh = String(d.getHours()).padStart(2, '0')
    const mi = String(d.getMinutes()).padStart(2, '0')
    const ss = String(d.getSeconds()).padStart(2, '0')
    return `${mm}/${dd}/${yy} ${hh}:${mi}:${ss}`
}

function coerceText(v) {
    if (v == null) return ''
    if (typeof v === 'string') return v
    if (typeof v === 'number') return String(v)
    if (Array.isArray(v)) return v.join(', ')
    if (typeof v === 'object') return v.title || v.name || v.label || v.value || String(v._id || '')
    return String(v)
}

function ensureAbsoluteLink(link) {
    const v = String(link || '').trim()
    if (!v) return ''
    if (/^https?:\/\//i.test(v)) return v
    const path = v.replace(/^https?:\/\/[^/]+/i, '').replace(/^\/+/, '')
    return `${SITE_BASE_URL}${path}`
}

function buildDynamicOrderPath(orderId = '') {
    const id = String(orderId || '').trim()
    return id ? `orders-status/${id}` : ''
}

function hasCmsGeneratedLink(record) {
    return !!(
        record?.['link-ordersStatus-orderId'] ||
        record?.['link-orders-status-orderId'] ||
        record?.['link-ordersStatus-title']
    )
}

async function getStatusRecordByRecordId(recordId = '') {
    const id = String(recordId || '').trim()
    if (!id) return null
    try {
        return await wixData.get(ORDERS_STATUS_COLLECTION, id, { suppressAuth: true, suppressHooks: true })
    } catch (error) {
        console.error(LOG_NS, 'getStatusRecordByRecordId failed:', { recordId: id, message: error?.message || '' })
        return null
    }
}

function pickEditLink(o, fallbackOrderId = '') {
    const raw =
        o['link-ordersStatus-orderId'] ||
        o['link-orders-status-orderId'] ||
        o['link-ordersStatus-title'] ||
        o.editLink ||
        buildDynamicOrderPath(fallbackOrderId) || ''
    return ensureAbsoluteLink(raw)
}