        <!-- Status & Loading Modal -->
        <div id="statusModal" class="fixed inset-0 bg-slate-900/40 z-[60] hidden flex items-center justify-center backdrop-blur-sm opacity-0 transition-opacity duration-300">
            <div class="bg-white rounded-xl shadow-2xl w-full max-w-sm overflow-hidden transform scale-95 transition-transform duration-300 mx-4 p-6 text-center" id="statusModalContent">
                
                <!-- Loading State -->
