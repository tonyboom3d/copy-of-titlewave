        <!-- Double confirmation modal -->
        <div id="confirmModal" class="fixed inset-0 bg-slate-900/40 z-[70] hidden flex items-center justify-center backdrop-blur-sm opacity-0 transition-opacity duration-300">
            <div id="confirmModalContent" class="bg-white rounded-2xl shadow-2xl w-full max-w-2xl overflow-hidden transform scale-95 transition-transform duration-300 mx-4">
                <div class="p-6 border-b border-slate-100">
                    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent-500 mb-2">Confirm changes</p>
                    <h3 class="text-xl md:text-2xl font-extrabold text-slate-900 tracking-tight">Please confirm before saving</h3>
                    <p class="text-sm text-slate-500 mt-2">Review exactly what will change. Nothing is saved until you confirm.</p>
                </div>
                <div class="p-6">
                    <div id="confirmList" class="space-y-3 max-h-[360px] overflow-auto custom-scrollbar pr-1"></div>
                </div>
                <div class="p-6 bg-slate-50 border-t border-slate-100 flex items-center justify-end gap-3">
                    <button id="confirmCancelBtn" class="px-5 py-2.5 rounded-xl border border-slate-200 bg-white text-slate-700 font-semibold hover:bg-slate-50 transition-colors">Cancel</button>
                    <button id="confirmOkBtn" class="px-5 py-2.5 rounded-xl bg-brand-600 text-white font-extrabold hover:bg-brand-700 transition-colors shadow-sm">Confirm & Save</button>
                </div>
            </div>
        </div>

    </main>

    <!-- Scripts -->
    <script>
        // --- Parent bridge (Wix/Velo host) ---
        const HOST_TYPES = {
            READY: 'TW_READY',
            REQUEST_STATE: 'TW_REQUEST_STATE',
            INIT: 'TW_INIT',
            SET_STATE: 'TW_SET_STATE',
            AUTH_SUBMIT: 'TW_AUTH_SUBMIT',
            AUTH_RESULT: 'TW_AUTH_RESULT',
            SAVE_SUBMIT: 'TW_SAVE_SUBMIT',
            SAVE_RESULT: 'TW_SAVE_RESULT',
            LOCK_EDITING: 'TW_LOCK_EDITING',
            ADMIN_LOGOUT: 'TW_ADMIN_LOGOUT',
            ADMIN_LOGOUT_RESULT: 'TW_ADMIN_LOGOUT_RESULT'
        }

        const LOG_NS = '[TW iframe UI]'
        function log(...args) {
            console.log(LOG_NS, ...args)
        }

        function maskEmail(email) {
            const s = String(email || '').trim()
            if (!s) return '(empty)'
            const at = s.indexOf('@')
            if (at < 1) return `${s.slice(0, 2)}...`
            return `${s.slice(0, 2)}...@${s.slice(at + 1)}`
        }

        function readAdminSession() {
            return null
        }

        function saveAdminSession(accessCode) {
            return accessCode
        }

        function clearAdminSession() {
            return true
        }

        function updateAdminSessionUi(isAdmin) {
            if (adminSessionBar) adminSessionBar.classList.toggle('hidden', !isAdmin)
        }

        function startAdminAuthLoading() {
            authSubmitBtn.setAttribute('disabled', 'true')
            authSubmitBtn.classList.add('opacity-80', 'cursor-not-allowed')
            authBtnText.classList.add('opacity-0')
            authBtnSpinner.classList.remove('hidden')
        }

        function attemptStoredAdminLogin() {
            return false
        }

        function promptRefreshAfterLogout() {
            const shouldRefresh = window.confirm('The admin session was removed from this device. Refresh the page now?')
            if (shouldRefresh) {
                window.location.reload()
            }
        }

        function buildAvatarDataUri(kind) {
            const isAdmin = kind === 'admin'
            const bg = isAdmin ? '#0f172a' : '#e2e8f0'
            const fg = isAdmin ? '#ffffff' : '#334155'
            const label = isAdmin ? 'CS' : 'U'
            const sub = isAdmin ? 'support' : 'user'
            const svg =
                `<svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 64 64">` +
                `<rect width="64" height="64" rx="32" fill="${bg}"/>` +
                `<text x="32" y="30" text-anchor="middle" font-family="Arial, sans-serif" font-size="22" font-weight="700" fill="${fg}">${label}</text>` +
                `<text x="32" y="46" text-anchor="middle" font-family="Arial, sans-serif" font-size="8" fill="${fg}" opacity="0.85">${sub}</text>` +
                `</svg>`
            return `data:image/svg+xml;charset=utf-8,${encodeURIComponent(svg)}`
        }

        let hostInit = { orderId: '', isAdminMode: false }
        let uiState = null
        let lockedEditing = false
        let lockedByHost = false
        let lockedByTimer = false
        let bypassTimeWindow = false
        let authMode = 'customer'
        let postSaveSummaryVisible = false
        let attemptedStoredAdminLogin = false
        let awaitingStoredAdminLogin = false
        let draftByRowKey = new Map() // rowKey -> partial fields
        let baseItemsByRowKey = new Map()
        const messagesSection = document.getElementById('messagesSection')
        const messagesThread = document.getElementById('messagesThread')
        const messageInput = document.getElementById('messageInput')
        const messageSendBtn = document.getElementById('messageSendBtn')
        const messagesLockedHint = document.getElementById('messagesLockedHint')
        const adminSessionBar = document.getElementById('adminSessionBar')
        const adminLogoutBtn = document.getElementById('adminLogoutBtn')

        function postToHost(payload) {
            try {
                log('-> host', payload?.type || '(no-type)', payload)
                window.parent.postMessage(payload, '*')
            } catch (e) {
                console.error(LOG_NS, 'postToHost failed:', e)
            }
        }

        // announce ready
        log('iframe booted; sending TW_READY')
        postToHost({ type: HOST_TYPES.READY })

        // --- Save Button & Checkbox Logic ---
        const termsCheckbox = document.getElementById('termsCheckbox');
        const saveButton = document.getElementById('saveButton');

        function getBaseItem(rowKey) {
            return baseItemsByRowKey.get(rowKey) || null
        }

        function buildMergedItem(item) {
            const patch = draftByRowKey.get(item?.rowKey || '') || {}
            return { ...(item || {}), ...patch }
        }

        function normalizeStatus(status) {
            if (Array.isArray(status)) {
                const first = status.find(Boolean)
                return first ? String(first).trim() : ''
            }
            return String(status || '').trim()
        }

        function formatStatusForDisplay(status) {
            const normalized = normalizeStatus(status)
            const lower = normalized.toLowerCase()
            if (lower === 'pending' || lower === 'pending (24h)') return 'Open for edits'
            return normalized
        }

        function getItemBadgeLabel(item, orderStatus = '') {
            const statusLabel = formatStatusForDisplay(item?.status || '')
            if (statusLabel && statusLabel !== 'Open for edits') return statusLabel
            const orderStatusLabel = formatStatusForDisplay(orderStatus || '')
            if (hasPersistedChanges(item) && orderStatusLabel && orderStatusLabel !== 'Open for edits') return orderStatusLabel
            return isItemChanged(item) ? 'Changed' : ''
        }

        function getStatusMeta(status) {
            const normalized = normalizeStatus(status)
            const lower = normalized.toLowerCase()

            if (lower === 'open for edits' || lower === 'pending' || lower === 'pending (24h)') {
                return null
            }

            if (lower === 'waiting for approval') {
                return {
                    tone: 'amber',
                    title: 'Change request in review',
                    message: 'We are still reviewing your change request, so additional edits are temporarily unavailable.',
                    iconPath: 'M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z'
                }
            }

            if (lower === 'approved') {
                return {
                    tone: 'green',
                    title: 'Change request approved',
                    message: 'Your change request has been approved. No further edits can be made to this order.',
                    iconPath: 'M5 13l4 4L19 7'
                }
            }

            if (lower === 'canceled' || lower === 'cancelled') {
                return {
                    tone: 'red',
                    title: 'Order canceled',
                    message: 'This order has been canceled, so its details can no longer be edited.',
                    iconPath: 'M6 18L18 6M6 6l12 12'
                }
            }

            if (lower === 'sent to production') {
                return {
                    tone: 'blue',
                    title: 'Order sent to production',
                    message: 'This order has already been sent to production and can no longer be edited.',
                    iconPath: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z'
                }
            }

            return null
        }

        function areDraftPatchesEqual(a, b) {
            const keys = ['size', 'color', 'colorLabel', 'colorHex', 'image', 'nameNumber', 'playerLastName']
            return keys.every(key => String(a?.[key] ?? '') === String(b?.[key] ?? ''))
        }

        function hasPersistedChanges(item) {
            return !!item?.persistedChanged
        }

        function isItemDirty(item) {
            const baseItem = getBaseItem(item?.rowKey || '')
            const patch = draftByRowKey.get(item?.rowKey || '')
            if (!baseItem || !patch) return false

            return (
                (patch.size ?? baseItem.size ?? '') !== (baseItem.size ?? '') ||
                (patch.color ?? baseItem.color ?? '') !== (baseItem.color ?? '') ||
                (patch.colorLabel ?? baseItem.colorLabel ?? '') !== (baseItem.colorLabel ?? '') ||
                (patch.colorHex ?? baseItem.colorHex ?? '') !== (baseItem.colorHex ?? '') ||
                (patch.image ?? baseItem.image ?? '') !== (baseItem.image ?? '') ||
                (patch.nameNumber ?? baseItem.nameNumber ?? '') !== (baseItem.nameNumber ?? '') ||
                (patch.playerLastName ?? baseItem.playerLastName ?? '') !== (baseItem.playerLastName ?? '')
            )
        }

        function hasActualChanges() {
            if (!uiState || !Array.isArray(uiState.items)) return false
            return uiState.items.some(isItemDirty)
        }

        function isItemChanged(item) {
            return hasPersistedChanges(item) || isItemDirty(item)
        }

        function refreshSaveButtonState() {
            const canSave =
                !!termsCheckbox.checked &&
                !lockedEditing &&
                hasActualChanges()

            if (canSave) {
                saveButton.removeAttribute('disabled')
                saveButton.classList.remove('bg-slate-200', 'text-slate-400', 'cursor-not-allowed')
                saveButton.classList.add('bg-slate-900', 'text-white', 'hover:bg-slate-800', 'hover:shadow-md', 'hover:-translate-y-0.5', 'cursor-pointer')
            } else {
                saveButton.setAttribute('disabled', 'true')
                saveButton.classList.add('bg-slate-200', 'text-slate-400', 'cursor-not-allowed')
                saveButton.classList.remove('bg-slate-900', 'text-white', 'hover:bg-slate-800', 'hover:shadow-md', 'hover:-translate-y-0.5', 'cursor-pointer')
            }
        }

        function renderMessages(state) {
            if (!messagesSection || !messagesThread) return
            const msgs = Array.isArray(state?.order?.messages) ? state.order.messages : []
            const allowed = state?.permissions?.messagingAllowed !== false
            const lockedHint = String(state?.permissions?.messagingHint || 'Messaging is locked for this order status.')

            messagesSection.classList.remove('hidden')
            messagesThread.innerHTML = ''

            if (!msgs.length) {
                const p = document.createElement('div')
                p.className = 'text-sm text-slate-500'
                p.textContent = 'No messages yet.'
                messagesThread.appendChild(p)
            } else {
                msgs.forEach(m => {
                    const role = String(m?.role || '').toLowerCase()
                    const isAdminMessage = role === 'admin'
                    const name = String(m?.displayName || m?.name || '')
                    const ts = String(m?.ts || '')
                    const text = String(m?.text || '')
                    const tone = isAdminMessage ? 'bg-slate-900 text-white' : 'bg-slate-100 text-slate-900'
                    const displayName = isAdminMessage ? 'Customer Service' : (name || 'Customer')
                    const avatarSrc = buildAvatarDataUri(isAdminMessage ? 'admin' : 'user')

                    const bubble = document.createElement('div')
                    bubble.className = `rounded-2xl p-4 ${tone}`
                    bubble.innerHTML = `
                        <div class="flex items-start gap-3">
                            <img src="${avatarSrc}" alt="${escapeHtml(displayName)}" class="w-10 h-10 rounded-full border border-white/20 shrink-0 object-cover">
                            <div class="min-w-0 flex-1">
                                <div class="text-xs opacity-80 font-semibold">${escapeHtml(displayName)} • ${escapeHtml(ts ? new Date(ts).toLocaleString() : '')}</div>
                                <div class="mt-2 text-sm leading-relaxed whitespace-pre-wrap">${escapeHtml(text)}</div>
                            </div>
                        </div>
                    `
                    messagesThread.appendChild(bubble)
                })
            }

            if (messageInput) messageInput.disabled = !allowed
            if (messageSendBtn) messageSendBtn.disabled = !allowed
            if (messagesLockedHint) {
                messagesLockedHint.textContent = lockedHint
                messagesLockedHint.classList.toggle('hidden', !!allowed)
            }
        }

        messageSendBtn?.addEventListener('click', () => {
            if (!uiState) return
            if (uiState?.permissions?.messagingAllowed === false) return
            const text = String(messageInput?.value || '').trim()
            if (!text) return
            if (messageInput) messageInput.value = ''
            postToHost({ type: 'TW_MESSAGE_SUBMIT', text })
        })

        termsCheckbox.addEventListener('change', refreshSaveButtonState);

        function syncEditingLockState() {
            lockedEditing = lockedByHost || lockedByTimer
            refreshSaveButtonState()
        }

        function showOrderExperience() {
            const orderExperience = document.getElementById('orderExperience')
            const postSaveSummary = document.getElementById('postSaveSummary')
            if (orderExperience) orderExperience.classList.remove('hidden')
            if (postSaveSummary) {
                postSaveSummary.classList.add('hidden')
                postSaveSummary.classList.remove('flex')
            }
            postSaveSummaryVisible = false
        }

        function showPostSaveSummary(statusText) {
            const orderExperience = document.getElementById('orderExperience')
            const postSaveSummary = document.getElementById('postSaveSummary')
            const statusEl = document.getElementById('postSaveStatusText')
            if (orderExperience) orderExperience.classList.add('hidden')
            if (postSaveSummary) {
                postSaveSummary.classList.remove('hidden')
                postSaveSummary.classList.add('flex')
            }
            if (statusEl) statusEl.textContent = formatStatusForDisplay(statusText) || 'Waiting for Approval'
            postSaveSummaryVisible = true
        }

        function updateStatusBanner(status) {
            const meta = getStatusMeta(status)
            const section = document.getElementById('statusBannerSection')
            const banner = document.getElementById('statusBanner')
            const iconWrap = document.getElementById('statusBannerIconWrap')
            const iconPath = document.getElementById('statusBannerIconPath')
            const titleEl = document.getElementById('statusBannerTitle')
            const messageEl = document.getElementById('statusBannerMessage')

            if (!section || !banner || !iconWrap || !iconPath || !titleEl || !messageEl) return

            if (!meta) {
                section.classList.add('hidden')
                return
            }

            const toneClasses = {
                amber: ['bg-amber-50', 'border-amber-200', 'text-amber-900', 'bg-amber-100', 'text-amber-700'],
                green: ['bg-green-50', 'border-green-200', 'text-green-900', 'bg-green-100', 'text-green-700'],
                red: ['bg-red-50', 'border-red-200', 'text-red-900', 'bg-red-100', 'text-red-700'],
                blue: ['bg-blue-50', 'border-blue-200', 'text-blue-900', 'bg-blue-100', 'text-blue-700']
            }
            const [bannerBg, bannerBorder, bannerText, iconBg, iconText] = toneClasses[meta.tone] || toneClasses.amber

            banner.className = `rounded-2xl border px-5 py-4 shadow-sm ${bannerBg} ${bannerBorder} ${bannerText}`
            iconWrap.className = `mt-0.5 w-9 h-9 rounded-full flex items-center justify-center shrink-0 ${iconBg} ${iconText}`
            iconPath.setAttribute('d', meta.iconPath)
            titleEl.textContent = meta.title
            messageEl.textContent = meta.message
            section.classList.remove('hidden')
        }

        // --- Live Timer Logic ---
        // Starts once we have createdDate from host.
        const totalDuration = 24 * 3600; // 24h window in seconds
        let timerIntervalId = 0
        let timerDeadlineMs = 0

        const elHours = document.getElementById('hours');
        const elMinutes = document.getElementById('minutes');
        const elSeconds = document.getElementById('seconds');
        const elProgressBar = document.getElementById('progressBar');
        const elTimeLeftText = document.getElementById('timeLeftText');
        const elTimerStatusMessage = document.getElementById('timerStatusMessage');

        function formatTime(val) {
            return val < 10 ? '0' + val : val;
        }

        function renderTimer(secondsRemaining) {
            const safeSeconds = Math.max(0, secondsRemaining)
            const h = Math.floor(safeSeconds / 3600);
            const m = Math.floor((safeSeconds % 3600) / 60);
            const s = Math.floor(safeSeconds % 60);

            elHours.textContent = formatTime(h);
            elMinutes.textContent = formatTime(m);
            elSeconds.textContent = formatTime(s);
            elTimeLeftText.textContent = `${formatTime(h)}:${formatTime(m)}:${formatTime(s)}`;
            elProgressBar.style.width = `${(safeSeconds / totalDuration) * 100}%`;

            if (elTimerStatusMessage) {
                if (!bypassTimeWindow && safeSeconds <= 0) {
                    elTimerStatusMessage.textContent = 'The 24-hour editing window has expired.'
                    elTimerStatusMessage.classList.remove('hidden')
                } else {
                    elTimerStatusMessage.textContent = ''
                    elTimerStatusMessage.classList.add('hidden')
                }
            }
        }

        function stopTimer() {
            if (timerIntervalId) {
                clearInterval(timerIntervalId)
                timerIntervalId = 0
            }
        }

        function tickTimer() {
            const secondsRemaining = timerDeadlineMs
                ? Math.max(0, Math.floor((timerDeadlineMs - Date.now()) / 1000))
                : 0

            renderTimer(secondsRemaining)

            const nextLockedByTimer = !bypassTimeWindow && !!timerDeadlineMs && secondsRemaining <= 0
            if (nextLockedByTimer !== lockedByTimer) {
                lockedByTimer = nextLockedByTimer
                syncEditingLockState()
            }

            if (secondsRemaining <= 0) {
                stopTimer()
            }
        }

        function startTimer(createdDateStr, shouldBypassTimeWindow = false) {
            stopTimer()
