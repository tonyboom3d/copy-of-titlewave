                if (!lines.length) {
                    const p = document.createElement('div')
                    p.className = 'text-sm text-slate-500 mt-3'
                    p.textContent = 'No visible field changes detected.'
                    wrap.appendChild(p)
                } else {
                    const ul = document.createElement('div')
                    ul.className = 'mt-3 space-y-2'
                    for (const ln of lines) {
                        const row = document.createElement('div')
                        row.className = 'grid grid-cols-12 gap-2 items-start text-sm'
                        row.innerHTML =
                            `<div class="col-span-3 text-slate-500 font-semibold">${escapeHtml(ln.label)}</div>` +
                            `<div class="col-span-4 text-slate-700"><span class="text-slate-400">from</span> ${escapeHtml(ln.before)}</div>` +
                            `<div class="col-span-5 text-slate-900 font-semibold"><span class="text-slate-400 font-normal">to</span> ${escapeHtml(ln.after)}</div>`
                        ul.appendChild(row)
                    }
                    wrap.appendChild(ul)
                }

                confirmList.appendChild(wrap)
            }

            confirmModal.classList.remove('hidden')
            void confirmModal.offsetWidth
            confirmModal.classList.remove('opacity-0')
            confirmModalContent.classList.remove('scale-95')
            return true
        }

        function hideConfirmModal() {
            if (!confirmModal || !confirmModalContent) return
            confirmModal.classList.add('opacity-0')
            confirmModalContent.classList.add('scale-95')
            window.setTimeout(() => {
                confirmModal.classList.add('hidden')
            }, 220)
        }

        confirmCancelBtn?.addEventListener('click', () => {
            pendingSavePayload = null
            hideConfirmModal()
        })

        confirmOkBtn?.addEventListener('click', () => {
            const payload = pendingSavePayload
            pendingSavePayload = null
            hideConfirmModal()
            if (!payload) return

            statusModal.classList.remove('hidden')
            void statusModal.offsetWidth
            statusModal.classList.remove('opacity-0')
            statusModalContent.classList.remove('scale-95')
            loadingState.classList.remove('hidden')
            successState.classList.add('hidden')

            if (Array.isArray(payload.adminDecisions)) {
                postToHost({ type: 'TW_ADMIN_DECISIONS_SUBMIT', decisions: payload.adminDecisions })
                return
            }

            postToHost({ type: HOST_TYPES.SAVE_SUBMIT, changes: payload.changes })
        })

        function renderAdminRequests(state) {
            const isAdmin = !!state?.permissions?.isAdminMode
            if (!adminRequestsSection || !adminRequestsList || !adminRequestsEmpty) return

            if (!isAdmin) {
                adminRequestsSection.classList.add('hidden')
                return
            }

            const items = Array.isArray(state?.items) ? state.items : []
            const requested = items.filter(it => !!it?.persistedChanged)

            adminRequestsList.innerHTML = ''
            if (!requested.length) {
                adminRequestsEmpty.classList.remove('hidden')
                adminRequestsSection.classList.remove('hidden')
                return
            }
            adminRequestsEmpty.classList.add('hidden')
            adminRequestsSection.classList.remove('hidden')

            requested.forEach(it => {
                const rowKey = String(it?.rowKey || '')
                const current = adminDecisionByRowKey.get(rowKey) || 'Waiting for Approval'

                const card = document.createElement('div')
                card.className = 'rounded-2xl border border-slate-200 bg-white p-4'

                const title = escapeHtml(it?.productName || 'Item')
                const summary = buildDiffSummary(it)

                card.innerHTML = `
                    <div class="flex items-start justify-between gap-4">
                        <div class="min-w-0">
                            <div class="font-extrabold text-slate-900">${title}</div>
                            <div class="text-xs text-slate-500 mt-1">Row: ${escapeHtml(rowKey || '—')}</div>
                            <div class="text-sm text-slate-600 mt-2">${summary || ''}</div>
                        </div>
                        <div class="shrink-0 flex flex-col gap-2 items-end">
                            <label class="text-xs font-semibold text-slate-500 uppercase tracking-[0.14em]">Decision</label>
                            <select data-rowkey="${escapeHtml(rowKey)}" class="adminDecisionSelect w-[230px] border border-slate-200 rounded-xl px-3 py-2 text-slate-900 font-semibold bg-white focus:outline-none focus:ring-2 focus:ring-brand-500">
                                ${ADMIN_STATUSES.map(s => `<option value="${escapeHtml(s)}"${s===current?' selected':''}>${escapeHtml(formatStatusForDisplay(s))}</option>`).join('')}
                            </select>
                        </div>
                    </div>
                `

                adminRequestsList.appendChild(card)
            })

            Array.from(adminRequestsList.querySelectorAll('.adminDecisionSelect')).forEach(sel => {
                sel.addEventListener('change', () => {
                    const rk = String(sel.getAttribute('data-rowkey') || '')
                    const v = String(sel.value || '')
                    if (!rk) return
                    adminDecisionByRowKey.set(rk, v)
                })
            })
        }

        function buildDiffSummary(item) {
            const parts = []
            const os = item?.originalSize || ''
            const ns = item?.size || ''
            if (String(os) !== String(ns)) parts.push(`Size: ${escapeHtml(os || '—')} → ${escapeHtml(ns || '—')}`)

            const oc = item?.originalColorLabel || item?.originalColor || ''
            const nc = item?.colorLabel || item?.color || ''
            if (String(oc) !== String(nc)) parts.push(`Color: ${escapeHtml(oc || '—')} → ${escapeHtml(nc || '—')}`)

            const on = item?.originalNameNumber || ''
            const nn = item?.nameNumber || ''
            if (String(on) !== String(nn)) parts.push(`Name/Number: ${escapeHtml(on || '—')} → ${escapeHtml(nn || '—')}`)

            const ol = item?.originalPlayerLastName || ''
            const nl = item?.playerLastName || ''
            if (String(ol) !== String(nl)) parts.push(`Last Name: ${escapeHtml(ol || '—')} → ${escapeHtml(nl || '—')}`)

            return parts.length ? parts.join(' • ') : 'Changes detected'
        }

        adminApproveAllBtn?.addEventListener('click', () => {
            if (!uiState || !Array.isArray(uiState.items)) return
            uiState.items.filter(it => !!it?.persistedChanged).forEach(it => adminDecisionByRowKey.set(String(it.rowKey || ''), 'Approved'))
            renderAdminRequests(uiState)
        })

        adminRejectAllBtn?.addEventListener('click', () => {
            if (!uiState || !Array.isArray(uiState.items)) return
            uiState.items.filter(it => !!it?.persistedChanged).forEach(it => adminDecisionByRowKey.set(String(it.rowKey || ''), 'Rejected'))
            renderAdminRequests(uiState)
        })

        adminSaveDecisionsBtn?.addEventListener('click', () => {
            if (!uiState || !Array.isArray(uiState.items)) return
            const requested = uiState.items.filter(it => !!it?.persistedChanged)
            if (!requested.length) return

            const decisions = requested.map(it => ({
                itemId: it.itemId || '',
                rowKey: it.rowKey || '',
                status: adminDecisionByRowKey.get(String(it.rowKey || '')) || 'Waiting for Approval',
                productName: it.productName || ''
            }))

            // reuse confirm modal as double confirmation
            pendingSavePayload = { adminDecisions: decisions }
            if (confirmList) {
                confirmList.innerHTML = ''
                decisions.forEach(d => {
                    const wrap = document.createElement('div')
                    wrap.className = 'rounded-2xl border border-slate-200 bg-white p-4'
                    wrap.innerHTML = `
                        <div class="font-extrabold text-slate-900">${escapeHtml(d.productName || 'Item')}</div>
                        <div class="text-xs text-slate-500 mt-1">Row: ${escapeHtml(d.rowKey || '—')}</div>
                        <div class="text-sm text-slate-700 mt-3"><span class="text-slate-400">Decision:</span> <span class="font-extrabold">${escapeHtml(formatStatusForDisplay(d.status || ''))}</span></div>
                    `
                    confirmList.appendChild(wrap)
                })
                confirmModal.classList.remove('hidden')
                void confirmModal.offsetWidth
                confirmModal.classList.remove('opacity-0')
                confirmModalContent.classList.remove('scale-95')
            } else {
                postToHost({ type: 'TW_ADMIN_DECISIONS_SUBMIT', decisions })
            }
        })

        saveButton.addEventListener('click', () => {
            log('save button clicked', {
                disabled: saveButton.hasAttribute('disabled'),
                lockedEditing,
                isAdminMode: hostInit.isAdminMode,
                hasState: !!uiState
            })
            if (saveButton.hasAttribute('disabled')) return
            if (lockedEditing) return
            if (!uiState || !Array.isArray(uiState.items)) return

            const changes = []
            for (const it of uiState.items) {
                const rowKey = it.rowKey || ''
                const patch = draftByRowKey.get(rowKey)
                if (!patch) continue
                changes.push({
                    itemId: it.itemId || '',
                    rowKey: it.rowKey || '',
                    productId: it.productId || '',
                    productName: it.productName || '',
                    size: ('size' in patch) ? patch.size : (it.size || ''),
                    color: ('color' in patch) ? patch.color : (it.color || ''),
                    colorLabel: ('colorLabel' in patch) ? patch.colorLabel : ((it.colorLabel || it.color || '')),
                    colorHex: ('colorHex' in patch) ? patch.colorHex : (it.colorHex || ''),
                    nameNumber: ('nameNumber' in patch) ? patch.nameNumber : (it.nameNumber || ''),
                    playerLastName: ('playerLastName' in patch) ? patch.playerLastName : (it.playerLastName || ''),
                    image: ('image' in patch) ? patch.image : (it.image || ''),
                    hasNameNumberField: !!it.hasNameNumberField,
                    hasPlayerLastNameField: !!it.hasPlayerLastNameField,
                    changes: Array.isArray(patch.changes) ? patch.changes : (Array.isArray(it.changes) ? it.changes : []),
                    lastChange: patch.lastChange || it.lastChange || null
                })
            }

            if (!changes.length) {
                refreshSaveButtonState()
                return
            }
            log('save submitting changes', { changeCount: changes.length, rowKeys: changes.map(x => x.rowKey) })

            const itemsByRowKey = new Map()
            for (const it of uiState.items) itemsByRowKey.set(String(it.rowKey || ''), it)
            pendingSavePayload = { changes }

            const opened = showConfirmModal(changes, itemsByRowKey)
            if (!opened) {
                pendingSavePayload = null
                statusModal.classList.remove('hidden')
                void statusModal.offsetWidth
                statusModal.classList.remove('opacity-0')
                statusModalContent.classList.remove('scale-95')
                loadingState.classList.remove('hidden')
                successState.classList.add('hidden')
                postToHost({ type: HOST_TYPES.SAVE_SUBMIT, changes })
            }
        })

        const hideStatusModal = () => {
            statusModal.classList.add('opacity-0');
            statusModalContent.classList.add('scale-95');
            setTimeout(() => {
                statusModal.classList.add('hidden');
            }, 300);
        };

        closeStatusModalBtn.addEventListener('click', hideStatusModal);

        // --- Auth Modal Logic ---
        const authModal = document.getElementById('authModal');
        const authSubmitBtn = document.getElementById('authSubmitBtn');
        const authCustomerFields = document.getElementById('authCustomerFields');
        const authAdminFields = document.getElementById('authAdminFields');
        const authOrderNumber = document.getElementById('authOrderNumber');
        const authEmail = document.getElementById('authEmail');
        const authAdminCode = document.getElementById('authAdminCode');
        const authErrorMsg = document.getElementById('authErrorMsg');
        const authErrorText = document.getElementById('authErrorText');
        const authBtnText = document.getElementById('authBtnText');
        const authBtnSpinner = document.getElementById('authBtnSpinner');
        const authHintText = document.getElementById('authHintText');
        const adminLoginToggleBtn = document.getElementById('adminLoginToggleBtn');
        const customerLoginToggleBtn = document.getElementById('customerLoginToggleBtn');

        function finishAuthLoadingWithDelay(callback) {
            window.setTimeout(() => {
                authSubmitBtn.removeAttribute('disabled')
                authSubmitBtn.classList.remove('opacity-80', 'cursor-not-allowed')
                authBtnText.classList.remove('opacity-0')
                authBtnSpinner.classList.add('hidden')
                if (typeof callback === 'function') callback()
            }, 1000)
        }

        function setAuthMode(nextMode) {
            authMode = nextMode === 'admin-code' ? 'admin-code' : 'customer'
            authErrorMsg.classList.add('hidden')
            authOrderNumber.classList.remove('border-red-500', 'focus:border-red-500', 'focus:ring-red-500');
            authEmail.classList.remove('border-red-500', 'focus:border-red-500', 'focus:ring-red-500');
            authAdminCode.classList.remove('border-red-500', 'focus:border-red-500', 'focus:ring-red-500');

            if (authMode === 'admin-code') {
                authCustomerFields.classList.add('hidden')
                authAdminFields.classList.remove('hidden')
                adminLoginToggleBtn.classList.add('hidden')
                customerLoginToggleBtn.classList.remove('hidden')
                authBtnText.textContent = 'Login as Admin'
                authHintText.textContent = 'Enter the admin code to bypass customer verification.'
            } else {
                authCustomerFields.classList.remove('hidden')
                authAdminFields.classList.add('hidden')
                adminLoginToggleBtn.classList.remove('hidden')
                customerLoginToggleBtn.classList.add('hidden')
                authBtnText.textContent = 'Submit & Verify'
                authHintText.textContent = 'Hint: Enter your order details to continue'
            }
        }

        adminLoginToggleBtn.addEventListener('click', () => setAuthMode('admin-code'))
        customerLoginToggleBtn.addEventListener('click', () => setAuthMode('customer'))
        adminLogoutBtn?.addEventListener('click', () => {
            clearAdminSession()
            postToHost({ type: HOST_TYPES.ADMIN_LOGOUT })
        })

        authSubmitBtn.addEventListener('click', () => {
            log('verify button clicked')
            if (authSubmitBtn.hasAttribute('disabled')) return;

            authErrorMsg.classList.add('hidden');
            authOrderNumber.classList.remove('border-red-500', 'focus:border-red-500', 'focus:ring-red-500');
            authEmail.classList.remove('border-red-500', 'focus:border-red-500', 'focus:ring-red-500');
            authAdminCode.classList.remove('border-red-500', 'focus:border-red-500', 'focus:ring-red-500');

            if (authMode === 'admin-code') {
                const adminCodeVal = authAdminCode.value.trim();
                log('admin auth form values', {
                    hasAdminCode: !!adminCodeVal,
                    hostOrderId: hostInit.orderId
                })

                if (adminCodeVal === '') {
                    authAdminCode.classList.add('border-red-500', 'focus:border-red-500', 'focus:ring-red-500');
                    return;
                }

                startAdminAuthLoading()

                log('sending TW_AUTH_SUBMIT admin-code')
                postToHost({ type: HOST_TYPES.AUTH_SUBMIT, mode: 'admin-code', adminCode: adminCodeVal })
                return
            }

            const orderVal = authOrderNumber.value.trim();
            const emailVal = authEmail.value.trim();
            log('auth form values', {
                orderNumberLength: orderVal.length,
                email: maskEmail(emailVal),
                hostOrderId: hostInit.orderId,
                isAdminMode: hostInit.isAdminMode
            })
            // Basic validation for empty fields
            let hasError = false;
            if(orderVal === '') {
                authOrderNumber.classList.add('border-red-500', 'focus:border-red-500', 'focus:ring-red-500');
                hasError = true;
            }
            if(emailVal === '') {
                authEmail.classList.add('border-red-500', 'focus:border-red-500', 'focus:ring-red-500');
                hasError = true;
            }

            if(hasError) return;

            // 1. Show Loading State
            authSubmitBtn.setAttribute('disabled', 'true');
            authSubmitBtn.classList.add('opacity-80', 'cursor-not-allowed');
            authBtnText.classList.add('opacity-0');
            authBtnSpinner.classList.remove('hidden');

            log('sending TW_AUTH_SUBMIT')
            postToHost({ type: HOST_TYPES.AUTH_SUBMIT, email: emailVal, orderNumber: orderVal })
        });

        // Remove error states when user types again
        authOrderNumber.addEventListener('input', () => {
            authErrorMsg.classList.add('hidden');
            authOrderNumber.classList.remove('border-red-500', 'focus:border-red-500', 'focus:ring-red-500');
        });
        
        authEmail.addEventListener('input', () => {
            authErrorMsg.classList.add('hidden');
            authEmail.classList.remove('border-red-500', 'focus:border-red-500', 'focus:ring-red-500');
        });

        authAdminCode.addEventListener('input', () => {
            authErrorMsg.classList.add('hidden');
            authAdminCode.classList.remove('border-red-500', 'focus:border-red-500', 'focus:ring-red-500');
        });

        // --- Incoming messages from host ---
        window.addEventListener('message', (ev) => {
            const d = ev?.data || {}
            if (!d || typeof d !== 'object') return
            log('<- host', d.type || '(no-type)', d)

            if (d.type === HOST_TYPES.INIT) {
                hostInit = { orderId: d.orderId || '', isAdminMode: !!d.isAdminMode }
                log('received TW_INIT', hostInit)
                // admin mode: no auth modal
                if (hostInit.isAdminMode) {
                    authModal.classList.add('hidden')
                    document.body.classList.remove('overflow-hidden')
                    updateAdminSessionUi(true)
                } else {
                    updateAdminSessionUi(false)
                    attemptStoredAdminLogin()
                }
                syncEditingLockState()
                return
            }

            if (d.type === HOST_TYPES.SET_STATE) {
                log('received TW_SET_STATE')
                uiState = d.state || null
                baseItemsByRowKey = new Map((uiState?.items || []).map(item => [item.rowKey, { ...item }]))
                if (uiState) {
                    setOrderMetaFromState(uiState)
                    if (!postSaveSummaryVisible) {
                        showOrderExperience()
                        renderItemsTable(uiState)
                    }
                }
                renderAdminRequests(uiState)
                renderMessages(uiState)
                updateAdminSessionUi(!!uiState?.permissions?.isAdminMode)
                refreshSaveButtonState()

                // hide auth if we now have order number
                if (uiState?.order?.number) {
                    authModal.classList.add('opacity-0')
                    setTimeout(() => {
                        authModal.classList.add('hidden')
                        document.body.classList.remove('overflow-hidden')
                    }, 200)
                }
                return
            }

            if (d.type === HOST_TYPES.AUTH_RESULT) {
                log('received TW_AUTH_RESULT', { ok: !!d.ok, message: d.message || '' })
                finishAuthLoadingWithDelay(() => {
                    if (!d.ok) {
                        if (awaitingStoredAdminLogin) {
                            clearAdminSession()
                            awaitingStoredAdminLogin = false
                        }
                        if (authErrorText && d.message) authErrorText.textContent = String(d.message)
                        authErrorMsg.classList.remove('hidden')
                        if (authMode === 'admin-code') {
                            authAdminCode.classList.add('border-red-500')
                        } else {
                            authOrderNumber.classList.add('border-red-500')
                            authEmail.classList.add('border-red-500')
                        }
                    } else if (authMode === 'admin-code') {
                        saveAdminSession(authAdminCode.value || '')
                        awaitingStoredAdminLogin = false
                        updateAdminSessionUi(true)
                    }
                })
                return
            }

            if (d.type === HOST_TYPES.SAVE_RESULT) {
                log('received TW_SAVE_RESULT', { ok: !!d.ok, message: d.message || '', newStatus: d.newStatus || '' })
                if (d.ok) {
                    draftByRowKey = new Map()
                    refreshSaveButtonState()
                    if (uiState?.permissions?.isAdminMode) {
                        loadingState.classList.add('hidden')
                        setStatusResultState({ ok: true, message: 'Admin decisions were saved successfully.' })
                        successState.classList.remove('hidden')
                    } else {
                        hideStatusModal()
                        showPostSaveSummary(d.newStatus || 'Waiting for Approval')
                    }
                } else {
                    setStatusResultState({ ok: false, message: d.message ? String(d.message) : 'Failed to save changes.' })
                    loadingState.classList.add('hidden')
                    successState.classList.remove('hidden')
                }
                return
            }

            if (d.type === HOST_TYPES.LOCK_EDITING) {
                log('received TW_LOCK_EDITING', { locked: !!d.locked, reason: d.reason || '' })
                lockedByHost = !!d.locked
                syncEditingLockState()
                return
            }

            if (d.type === 'TW_MESSAGE_RESULT') {
                if (!d.ok) {
                    log('message send failed', { message: d.message || '' })
                    if (messagesLockedHint) {
                        messagesLockedHint.textContent = String(d.message || 'Failed to send message.')
                        messagesLockedHint.classList.remove('hidden')
                    }
                }
                return
            }

            if (d.type === HOST_TYPES.ADMIN_LOGOUT_RESULT) {
                clearAdminSession()
                updateAdminSessionUi(false)
                uiState = null
                draftByRowKey = new Map()
                baseItemsByRowKey = new Map()
                setAuthMode('customer')
                authModal.classList.remove('hidden')
                document.body.classList.add('overflow-hidden')
                promptRefreshAfterLogout()
                return
            }
        })

        // In case the host missed our initial ready, ask for state soon
        setTimeout(() => {
            log('sending TW_REQUEST_STATE fallback')
            postToHost({ type: HOST_TYPES.REQUEST_STATE })
        }, 300)

    </script>
</body>
</html>