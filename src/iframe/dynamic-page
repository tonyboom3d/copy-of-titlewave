        function ensureOption(options, value, label = value) {
            const normalizedValue = String(value || '')
            const normalizedLabel = String(label || '')
            if (!normalizedValue) return options
            const exists = options.some(option => {
                const optionValue = String(option?.value || '').toLowerCase()
                const optionLabel = String(option?.label || option?.value || '').toLowerCase()
                return (
                    optionValue === normalizedValue.toLowerCase() ||
                    optionLabel === normalizedValue.toLowerCase() ||
                    (!!normalizedLabel && optionLabel === normalizedLabel.toLowerCase())
                )
            })
            if (exists) return options
            return [{ value: normalizedValue, label: label || normalizedValue }, ...options]
        }

        function dedupeOptions(options, keyBuilder = option => `${option?.value || ''}::${option?.label || ''}::${option?.color || ''}`) {
            const seen = new Set()
            const out = []
            ;(options || []).forEach(option => {
                const key = keyBuilder(option)
                if (!key || seen.has(key)) return
                seen.add(key)
                out.push(option)
            })
            return out
        }

        function findColorOption(options, value, label = '') {
            const valueLower = String(value || '').toLowerCase()
            const labelLower = String(label || '').toLowerCase()

            return (options || []).find(option => {
                const optionValue = String(option?.value || '').toLowerCase()
                const optionLabel = String(option?.label || option?.value || '').toLowerCase()
                return (
                    (!!valueLower && (optionValue === valueLower || optionLabel === valueLower)) ||
                    (!!labelLower && (optionValue === labelLower || optionLabel === labelLower))
                )
            }) || null
        }

