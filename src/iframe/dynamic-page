<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Order Details</title>
    
    <!-- Google Fonts for English -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Tailwind Config -->
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                    },
                    colors: {
                        brand: {
                            50: '#f0fdfa',
                            100: '#ccfbf1',
                            500: '#14b8a6', // Teal
                            600: '#0d9488',
                            900: '#134e4a',
                        },
                        accent: {
                            500: '#f97316', // Orange
                        }
                    }
                }
            }
        }
    </script>
    
    <style>
        /* Custom Scrollbar */
        .custom-scrollbar::-webkit-scrollbar {
            height: 8px;
            width: 8px;
        }
        .custom-scrollbar::-webkit-scrollbar-track {
            background: #f1f5f9; 
            border-radius: 4px;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: #cbd5e1; 
            border-radius: 4px;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: #94a3b8; 
        }
        
        /* Blinking animation for timer dots */
        @keyframes pulse-opacity {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.3; }
        }
        .animate-blink {
            animation: pulse-opacity 1s infinite;
        }
    </style>
</head>
<body class="bg-slate-50 text-slate-800 antialiased selection:bg-brand-100 selection:text-brand-900 overflow-hidden">

    <!-- Auth / Verification Modal -->
    <div id="authModal" class="fixed inset-0 z-[100] flex items-center justify-center bg-slate-900/40 backdrop-blur-sm transition-opacity duration-500">
        <div class="bg-white w-full max-w-md p-8 shadow-2xl rounded-2xl relative mx-4 transform transition-transform duration-300">
            
            <!-- Icon -->
            <div class="w-16 h-16 bg-accent-50 text-accent-500 rounded-full flex items-center justify-center mx-auto mb-5">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
            </div>
            
            <h2 class="text-2xl font-bold text-center text-slate-800 mb-2">Verify Your Order</h2>
            <p class="text-slate-500 text-center text-sm mb-6">
                Please enter your order details below to access and edit your items.
            </p>
            
            <!-- Error Message Container (Hidden by default) -->
            <div id="authErrorMsg" class="hidden bg-red-50 border border-red-200 text-red-600 text-sm rounded-xl p-3 mb-6 flex items-start gap-2.5">
                <svg class="w-5 h-5 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    <span id="authErrorText">Incorrect order number or email. Please check your details and try again.</span>
            </div>

            <div id="authCustomerFields" class="flex flex-col gap-4 mb-8">
                <div class="flex flex-col gap-1.5">
                    <label class="text-slate-700 font-semibold text-sm">Order Number <span class="text-red-500">*</span></label>
                    <input type="text" id="authOrderNumber" placeholder="e.g. 10011" class="w-full px-4 py-3 text-slate-800 bg-slate-50 border border-slate-200 focus:bg-white focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500 rounded-xl transition-all shadow-sm">
                </div>
                <div class="flex flex-col gap-1.5">
                    <label class="text-slate-700 font-semibold text-sm">Email Address <span class="text-red-500">*</span></label>
                    <input type="email" id="authEmail" placeholder="e.g. test@gg.com" class="w-full px-4 py-3 text-slate-800 bg-slate-50 border border-slate-200 focus:bg-white focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500 rounded-xl transition-all shadow-sm">
                </div>
            </div>

            <div id="authAdminFields" class="hidden flex flex-col gap-4 mb-8">
                <div class="flex flex-col gap-1.5">
                    <label class="text-slate-700 font-semibold text-sm">Admin Code <span class="text-red-500">*</span></label>
                    <input type="password" id="authAdminCode" placeholder="Enter admin code" class="w-full px-4 py-3 text-slate-800 bg-slate-50 border border-slate-200 focus:bg-white focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500 rounded-xl transition-all shadow-sm">
                </div>
            </div>

            <div class="flex flex-col gap-3">
                <button id="authSubmitBtn" class="w-full bg-accent-500 text-white font-bold text-lg py-3.5 rounded-xl hover:bg-accent-600 hover:shadow-lg hover:-translate-y-0.5 transition-all flex items-center justify-center gap-2 relative">
                    <span id="authBtnText">Submit & Verify</span>
                    <!-- Loading Spinner -->
                    <svg id="authBtnSpinner" class="animate-spin h-6 w-6 text-white hidden absolute" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                </button>
                
                <!-- Demo Hint -->
                <p id="authHintText" class="text-center text-xs text-slate-400 mt-2">
                    Hint: Enter your order details to continue
                </p>
                <button id="adminLoginToggleBtn" type="button" class="text-center text-xs text-slate-500 hover:text-slate-700 underline underline-offset-2 transition-colors">
                    Admin login
                </button>
                <button id="customerLoginToggleBtn" type="button" class="hidden text-center text-xs text-slate-500 hover:text-slate-700 underline underline-offset-2 transition-colors">
                    Back to customer login
                </button>
            </div>
        </div>
    </div>

    <!-- Main Container -->
    <main class="max-w-5xl mx-auto px-4 py-8 md:py-12 space-y-10">
        <section id="postSaveSummary" class="hidden min-h-[70vh] flex-col items-center justify-center">
            <div class="w-full max-w-2xl bg-white border border-slate-200 rounded-3xl shadow-xl p-8 md:p-10 text-center">
                <div class="w-16 h-16 mx-auto mb-5 rounded-full bg-green-100 text-green-600 flex items-center justify-center">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                </div>
                <p id="postSaveEyebrow" class="text-sm font-semibold tracking-[0.18em] text-accent-500 uppercase mb-3">Change Request Received</p>
                <h2 id="postSaveTitle" class="text-3xl md:text-4xl font-extrabold text-slate-900 tracking-tight mb-4">Thank you, we have received your update request.</h2>
                <p id="postSaveMessage" class="text-base md:text-lg leading-relaxed text-slate-600 max-w-xl mx-auto mb-6">
                    Our team is now reviewing the changes you submitted. We will update you as soon as possible. You can return to this link at any time to track your order status.
                </p>
                <div class="inline-flex flex-col items-center gap-2 bg-amber-50 border border-amber-200 rounded-2xl px-5 py-4">
                    <span class="text-xs font-semibold uppercase tracking-[0.18em] text-amber-700">Current Status</span>
                    <span id="postSaveStatusText" class="text-lg font-bold text-amber-800">Waiting for Approval</span>
                </div>
            </div>
        </section>

        <div id="orderExperience" class="space-y-10">
        <section id="statusBannerSection" class="hidden">
            <div id="statusBanner" class="rounded-2xl border px-5 py-4 shadow-sm">
                <div class="flex items-start gap-3">
                    <div id="statusBannerIconWrap" class="mt-0.5 w-9 h-9 rounded-full flex items-center justify-center shrink-0">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path id="statusBannerIconPath" stroke-linecap="round" stroke-linejoin="round" stroke-width="2.2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    </div>
                    <div class="flex-1">
                        <p id="statusBannerTitle" class="font-bold text-base">Order status update</p>
                        <p id="statusBannerMessage" class="text-sm leading-relaxed mt-1"></p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Timer Section -->
        <section class="flex flex-col items-center">
            <div class="flex items-center gap-3 mb-6">
                <h2 class="text-xl md:text-2xl font-bold text-slate-800">Time Left to Edit Your Order</h2>
                <span class="bg-white border border-slate-200 text-slate-500 text-xs font-medium px-3 py-1 rounded-full shadow-sm">
                    24h window
                </span>
            </div>

            <div class="flex items-center justify-center gap-3 md:gap-6">
                <!-- Hours -->
                <div class="flex flex-col items-center">
                    <div class="bg-white border border-slate-200 rounded-2xl w-20 h-24 md:w-28 md:h-32 flex items-center justify-center shadow-[0_8px_30px_rgb(0,0,0,0.04)] text-4xl md:text-6xl font-black text-slate-800 transition-transform hover:-translate-y-1 duration-300">
                        <span id="hours">02</span>
                    </div>
                    <span class="text-xs md:text-sm text-brand-500 mt-3 font-semibold tracking-wide uppercase">HOURS</span>
                </div>

                <div class="text-3xl md:text-5xl font-black text-accent-500 pb-8 animate-blink">:</div>

                <!-- Minutes -->
                <div class="flex flex-col items-center">
                    <div class="bg-white border border-slate-200 rounded-2xl w-20 h-24 md:w-28 md:h-32 flex items-center justify-center shadow-[0_8px_30px_rgb(0,0,0,0.04)] text-4xl md:text-6xl font-black text-slate-800 transition-transform hover:-translate-y-1 duration-300">
                        <span id="minutes">45</span>
                    </div>
                    <span class="text-xs md:text-sm text-brand-500 mt-3 font-semibold tracking-wide uppercase">MINUTES</span>
                </div>

                <div class="text-3xl md:text-5xl font-black text-accent-500 pb-8 animate-blink">:</div>

                <!-- Seconds -->
                <div class="flex flex-col items-center">
                    <div class="bg-white border border-slate-200 rounded-2xl w-20 h-24 md:w-28 md:h-32 flex items-center justify-center shadow-[0_8px_30px_rgb(0,0,0,0.04)] text-4xl md:text-6xl font-black text-slate-800 transition-transform hover:-translate-y-1 duration-300">
                        <span id="seconds">30</span>
                    </div>
                    <span class="text-xs md:text-sm text-brand-500 mt-3 font-semibold tracking-wide uppercase">SECONDS</span>
                </div>
            </div>

            <!-- Progress Bar -->
            <div class="w-full max-w-lg mt-10">
                <div class="h-2.5 w-full bg-slate-200 rounded-full overflow-hidden flex justify-end">
                    <div id="progressBar" class="h-full bg-accent-500 rounded-full transition-all duration-1000 ease-linear" style="width: 75%;"></div>
                </div>
                <div class="flex justify-between items-center mt-2 text-xs font-medium text-slate-400">
                    <span>100%</span>
                    <span><span id="timeLeftText">02:45:30</span> left</span>
                </div>
                <p id="timerStatusMessage" class="hidden mt-2 text-sm font-semibold text-red-600"></p>
            </div>
        </section>

        <!-- Divider -->
        <hr class="border-slate-200">

        <!-- Order Details Section -->
        <section>
            <h1 class="text-2xl md:text-3xl font-extrabold text-slate-900 tracking-tight mb-6 uppercase flex items-center gap-3">
                YOUR ORDER DETAILS <span id="orderNumber" class="text-brand-600">#—</span>
            </h1>

            <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
                <div class="grid grid-cols-1 md:grid-cols-2">
                    
                    <!-- Contact Info -->
                    <div class="p-6 md:p-8 border-b md:border-b-0 md:border-r border-slate-100">
                        <h3 class="text-lg font-bold text-slate-800 mb-4 flex items-center gap-2">
                            <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                            Contact Info:
                        </h3>
                        <ul class="space-y-3 text-slate-600">
                            <li class="flex items-start">
                                <span class="font-semibold w-20 text-slate-700">Name:</span>
                                <span id="contactName">—</span>
                            </li>
                            <li class="flex items-start">
                                <span class="font-semibold w-20 text-slate-700">Email:</span>
                                <span id="contactEmail">—</span>
                            </li>
                            <li class="flex items-start">
                                <span class="font-semibold w-20 text-slate-700">Phone:</span>
                                <span id="contactPhone">—</span>
                            </li>
                        </ul>
                    </div>

                    <!-- Shipping Info -->
                    <div class="p-6 md:p-8 bg-slate-50/50">
                        <h3 class="text-lg font-bold text-slate-800 mb-4 flex items-center gap-2">
                            <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
                            Shipping Info:
                        </h3>
                        <div class="text-slate-600 leading-relaxed">
                            <span class="font-semibold text-slate-700 block mb-1">Address:</span>
                            <span id="shippingAddress">—</span>
                        </div>
                    </div>
                </div>
                
                <!-- Footer -->
                <div class="bg-slate-50 border-t border-slate-100 p-4 px-6 md:px-8 text-sm text-slate-500">
                    Need to change your personal details ? 
                    <a href="#" class="text-brand-600 font-semibold hover:text-brand-700 hover:underline transition-all">Contact Support</a>
                </div>
            </div>
        </section>

        <!-- Order Status Section -->
        <section>
            <h2 class="text-2xl font-extrabold text-slate-900 tracking-tight uppercase mb-6">YOUR ORDER STATUS:</h2>
            <div class="flex flex-col md:flex-row md:items-end justify-between mb-4 gap-2">
                <div>
                    <p id="orderStatusText" class="text-slate-600 text-lg font-medium">—</p>
                </div>
                <div class="text-sm font-medium text-slate-500 flex items-center gap-1.5">
                    Click on a products to edit<span class="text-red-500">*</span>
                </div>
            </div>

            <!-- Table -->
            <div class="bg-white rounded-lg shadow-sm border border-slate-200 overflow-hidden">
                <div class="overflow-x-auto custom-scrollbar">
                    <table class="w-full text-center border-collapse min-w-[800px]">
                        <thead>
                            <tr class="bg-black text-white text-sm">
                                <th class="py-4 px-6 font-semibold w-24">Image</th>
                                <th class="py-4 px-6 font-semibold border-l border-slate-700">product name</th>
                                <th class="py-4 px-6 font-semibold border-l border-slate-700">Size</th>
                                <th class="py-4 px-6 font-semibold border-l border-slate-700">Color</th>
                                <th class="py-4 px-6 font-semibold border-l border-slate-700">Name \ Number</th>
                            </tr>
                        </thead>
                        <tbody id="itemsTbody" class="divide-y divide-slate-200"></tbody>
                    </table>
                </div>
                
                <!-- Pagination -->
                <div class="bg-white border-t border-slate-200 p-3 flex justify-center items-center gap-4 text-sm text-slate-600">
                    <button class="p-1 text-slate-400 hover:text-slate-800 disabled:opacity-50 transition-colors" disabled>
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                    </button>
                    <span class="font-medium">Page 1 of 1</span>
                    <button class="p-1 text-slate-400 hover:text-slate-800 disabled:opacity-50 transition-colors" disabled>
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                    </button>
                </div>
            </div>
        </section>

        <!-- Actions -->
        <section class="flex flex-col items-start mt-8 space-y-6">
            
            <!-- Terms Checkbox -->
            <label class="flex items-center gap-3 cursor-pointer group">
                <div class="relative flex items-center">
                    <input type="checkbox" id="termsCheckbox" class="peer sr-only">
                    <div class="w-6 h-6 bg-white border border-slate-400 rounded-sm peer-checked:bg-brand-500 peer-checked:border-brand-500 transition-all flex items-center justify-center">
                        <svg class="w-4 h-4 text-white opacity-0 peer-checked:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="4" d="M5 13l4 4L19 7"></path></svg>
                    </div>
                </div>
                <span class="text-slate-700">
                    I agree to the <a href="#" class="underline hover:text-slate-900">terms and conditions</a>
                </span>
            </label>

            <!-- Save Button -->
            <button id="saveButton" disabled class="w-full max-w-md py-4 rounded-lg font-bold text-lg transition-all duration-300 bg-slate-200 text-slate-400 cursor-not-allowed transform mx-auto">
                Save All
            </button>
            
        </section>

        <!-- Edit Product Modal -->
        <div id="editModal" class="fixed inset-0 bg-slate-900/40 z-50 hidden flex items-center justify-center backdrop-blur-sm opacity-0 transition-opacity duration-300">
            <div class="bg-white rounded-xl shadow-2xl w-full max-w-lg overflow-hidden transform scale-95 transition-transform duration-300 mx-4" id="editModalContent">
                <!-- Header -->
                <div class="flex justify-between items-center p-4 border-b border-slate-100">
                    <h3 class="font-bold text-lg text-slate-800">Edit Details</h3>
                    <button id="closeModalBtn" class="text-slate-400 hover:text-slate-600 transition-colors">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                    </button>
                </div>
                
                <!-- Body -->
                <div class="p-6 flex gap-6 items-start">
                    <!-- Left Column (Image & Reset) -->
                    <div class="flex flex-col items-center gap-4 w-1/3 shrink-0">
                        <span class="text-slate-500 font-medium">X1</span>
                        <div class="w-24 h-24 bg-black rounded-lg overflow-hidden border border-slate-200 shadow-sm" id="modalImgContainer">
                            <img id="modalImg" src="" alt="Product" class="w-full h-full object-cover">
                        </div>
                        <button id="resetModalBtn" class="flex items-center gap-1.5 text-accent-500 font-bold hover:text-accent-600 transition-colors text-sm mt-1">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
                            Reset
                        </button>
                    </div>
                    
                    <!-- Right Column (Inputs) -->
                    <div class="flex flex-col flex-1 gap-5 w-full">
                        <h4 id="modalTitle" class="text-slate-800 font-medium text-lg leading-tight">Soflo Hockey Jersey - Black</h4>
                        
                        <!-- Size Dropdown -->
                        <div class="flex flex-col gap-1.5 relative">
                            <label class="text-sm text-slate-600 font-medium">Size</label>
                            <div class="relative">
                                <select id="modalSize" class="w-full border border-slate-300 rounded-md px-3 py-2 text-slate-800 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500 appearance-none bg-white cursor-pointer shadow-sm">
                                    <!-- Options populated by JS -->
                                </select>
                                <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-3 text-slate-500">
                                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                                </div>
                            </div>
                        </div>

                        <!-- Color Dropdown -->
                        <div id="modalColorGroup" class="hidden flex flex-col gap-1.5 relative">
                            <label class="text-sm text-slate-600 font-medium">Color</label>
                            <div class="flex items-center gap-3">
                                <div class="relative flex-1">
                                    <select id="modalColor" class="w-full border border-slate-300 rounded-md px-3 py-2 text-slate-800 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500 appearance-none bg-white cursor-pointer shadow-sm">
                                        <!-- Options populated by JS -->
                                    </select>
                                    <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-3 text-slate-500">
                                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                                    </div>
                                </div>
                                <span id="modalColorSwatch" class="hidden inline-block w-8 h-8 rounded-full border border-slate-300 shadow-sm shrink-0"></span>
                            </div>
                        </div>

                        <!-- Name & Number Input -->
                        <div class="flex flex-col gap-1.5">
                            <label class="text-sm text-slate-600 font-medium">Name and Number</label>
                            <input type="text" id="modalNameNumber" class="w-full border border-slate-300 rounded-md px-3 py-2 text-slate-800 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500 shadow-sm" value="Test 28">
                        </div>

                        <div id="modalChangesPanel" class="hidden rounded-xl border border-amber-200 bg-amber-50/80 p-4">
                            <div class="flex items-center gap-2 mb-3">
                                <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-amber-100 text-amber-700">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
                                </span>
                                <div>
                                    <p class="text-sm font-bold text-amber-900">Change summary</p>
                                    <p class="text-xs text-amber-700">Review what was changed from the original order.</p>
                                </div>
                            </div>
                            <div id="modalChangesList" class="space-y-2.5"></div>
                        </div>
                    </div>
                </div>
                
                <!-- Footer -->
                <div class="p-4 border-t border-slate-100 bg-slate-50 flex justify-end gap-3 rounded-b-xl">
                    <button id="cancelModalBtn" class="px-5 py-2 text-slate-600 font-medium hover:bg-slate-200 rounded-lg transition-colors">Cancel</button>
                    <button id="saveModalBtn" class="px-5 py-2 bg-brand-600 text-white font-medium hover:bg-brand-700 rounded-lg transition-colors shadow-sm">Save</button>
                </div>
            </div>
        </div>

        </div>

        <!-- Status & Loading Modal -->
        <div id="statusModal" class="fixed inset-0 bg-slate-900/40 z-[60] hidden flex items-center justify-center backdrop-blur-sm opacity-0 transition-opacity duration-300">
            <div class="bg-white rounded-xl shadow-2xl w-full max-w-sm overflow-hidden transform scale-95 transition-transform duration-300 mx-4 p-6 text-center" id="statusModalContent">
                
                <!-- Loading State -->
                <div id="loadingState" class="flex flex-col items-center justify-center py-6">
                    <svg class="animate-spin h-10 w-10 text-brand-500 mb-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                    <p class="text-slate-600 font-medium">Saving your changes...</p>
                </div>

                <!-- Success State -->
                <div id="successState" class="hidden flex flex-col items-center justify-center py-4">
                    <div class="w-14 h-14 bg-green-100 text-green-500 rounded-full flex items-center justify-center mb-4">
                        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                    </div>
                    <h3 class="text-xl font-bold text-slate-800 mb-2">Thank You!</h3>
                    <p class="text-slate-600 text-sm leading-relaxed mb-6">
                        The information was saved successfully and transferred to customer service for further processing.
                    </p>
                    <button id="closeStatusModalBtn" class="w-full py-2.5 bg-slate-900 text-white font-medium rounded-lg hover:bg-slate-800 transition-colors">Close</button>
                </div>

            </div>
        </div>

    </main>

    <!-- Scripts -->
    <script>
        // --- Parent bridge (Wix/Velo host) ---
        const HOST_TYPES = {
            READY: 'TW_READY',
            REQUEST_STATE: 'TW_REQUEST_STATE',
            INIT: 'TW_INIT',
            SET_STATE: 'TW_SET_STATE',
            AUTH_SUBMIT: 'TW_AUTH_SUBMIT',
            AUTH_RESULT: 'TW_AUTH_RESULT',
            SAVE_SUBMIT: 'TW_SAVE_SUBMIT',
            SAVE_RESULT: 'TW_SAVE_RESULT',
            LOCK_EDITING: 'TW_LOCK_EDITING'
        }

        const LOG_NS = '[TW iframe UI]'

        function log(...args) {
            console.log(LOG_NS, ...args)
        }

        function maskEmail(email) {
            const s = String(email || '').trim()
            if (!s) return '(empty)'
            const at = s.indexOf('@')
            if (at < 1) return `${s.slice(0, 2)}...`
            return `${s.slice(0, 2)}...@${s.slice(at + 1)}`
        }

        let hostInit = { orderId: '', isAdminMode: false }
        let uiState = null
        let lockedEditing = false
        let lockedByHost = false
        let lockedByTimer = false
        let bypassTimeWindow = false
        let authMode = 'customer'
        let postSaveSummaryVisible = false
        let draftByRowKey = new Map() // rowKey -> partial fields
        let baseItemsByRowKey = new Map()

        function postToHost(payload) {
            try {
                log('-> host', payload?.type || '(no-type)', payload)
                window.parent.postMessage(payload, '*')
            } catch (e) {
                console.error(LOG_NS, 'postToHost failed:', e)
            }
        }

        // announce ready
        log('iframe booted; sending TW_READY')
        postToHost({ type: HOST_TYPES.READY })

        // --- Save Button & Checkbox Logic ---
        const termsCheckbox = document.getElementById('termsCheckbox');
        const saveButton = document.getElementById('saveButton');

        function getBaseItem(rowKey) {
            return baseItemsByRowKey.get(rowKey) || null
        }

        function buildMergedItem(item) {
            const patch = draftByRowKey.get(item?.rowKey || '') || {}
            return { ...(item || {}), ...patch }
        }

        function normalizeStatus(status) {
            if (Array.isArray(status)) {
                const first = status.find(Boolean)
                return first ? String(first).trim() : ''
            }
            return String(status || '').trim()
        }

        function getStatusMeta(status) {
            const normalized = normalizeStatus(status)
            const lower = normalized.toLowerCase()

            if (lower === 'waiting for approval') {
                return {
                    tone: 'amber',
                    title: 'Change request in review',
                    message: 'We are still reviewing your change request, so additional edits are temporarily unavailable.',
                    iconPath: 'M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z'
                }
            }

            if (lower === 'approved') {
                return {
                    tone: 'green',
                    title: 'Change request approved',
                    message: 'Your change request has been approved. No further edits can be made to this order.',
                    iconPath: 'M5 13l4 4L19 7'
                }
            }

            if (lower === 'canceled' || lower === 'cancelled') {
                return {
                    tone: 'red',
                    title: 'Order canceled',
                    message: 'This order has been canceled, so its details can no longer be edited.',
                    iconPath: 'M6 18L18 6M6 6l12 12'
                }
            }

            if (lower === 'sent to production') {
                return {
                    tone: 'blue',
                    title: 'Order sent to production',
                    message: 'This order has already been sent to production and can no longer be edited.',
                    iconPath: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z'
                }
            }

            return null
        }

        function areDraftPatchesEqual(a, b) {
            const keys = ['size', 'color', 'colorLabel', 'colorHex', 'image', 'nameNumber']
            return keys.every(key => String(a?.[key] ?? '') === String(b?.[key] ?? ''))
        }

        function hasPersistedChanges(item) {
            return !!item?.persistedChanged
        }

        function isItemDirty(item) {
            const baseItem = getBaseItem(item?.rowKey || '')
            const patch = draftByRowKey.get(item?.rowKey || '')
            if (!baseItem || !patch) return false

            return (
                (patch.size ?? baseItem.size ?? '') !== (baseItem.size ?? '') ||
                (patch.color ?? baseItem.color ?? '') !== (baseItem.color ?? '') ||
                (patch.colorLabel ?? baseItem.colorLabel ?? '') !== (baseItem.colorLabel ?? '') ||
                (patch.colorHex ?? baseItem.colorHex ?? '') !== (baseItem.colorHex ?? '') ||
                (patch.image ?? baseItem.image ?? '') !== (baseItem.image ?? '') ||
                (patch.nameNumber ?? baseItem.nameNumber ?? '') !== (baseItem.nameNumber ?? '')
            )
        }

        function hasActualChanges() {
            if (!uiState || !Array.isArray(uiState.items)) return false
            return uiState.items.some(isItemDirty)
        }

        function isItemChanged(item) {
            return hasPersistedChanges(item) || isItemDirty(item)
        }

        function refreshSaveButtonState() {
            const canSave =
                !!termsCheckbox.checked &&
                !lockedEditing &&
                hasActualChanges()

            if (canSave) {
                saveButton.removeAttribute('disabled')
                saveButton.classList.remove('bg-slate-200', 'text-slate-400', 'cursor-not-allowed')
                saveButton.classList.add('bg-slate-900', 'text-white', 'hover:bg-slate-800', 'hover:shadow-md', 'hover:-translate-y-0.5', 'cursor-pointer')
            } else {
                saveButton.setAttribute('disabled', 'true')
                saveButton.classList.add('bg-slate-200', 'text-slate-400', 'cursor-not-allowed')
                saveButton.classList.remove('bg-slate-900', 'text-white', 'hover:bg-slate-800', 'hover:shadow-md', 'hover:-translate-y-0.5', 'cursor-pointer')
            }
        }

        termsCheckbox.addEventListener('change', refreshSaveButtonState);

        function syncEditingLockState() {
            lockedEditing = lockedByHost || lockedByTimer
            refreshSaveButtonState()
        }

        function showOrderExperience() {
            const orderExperience = document.getElementById('orderExperience')
            const postSaveSummary = document.getElementById('postSaveSummary')
            if (orderExperience) orderExperience.classList.remove('hidden')
            if (postSaveSummary) {
                postSaveSummary.classList.add('hidden')
                postSaveSummary.classList.remove('flex')
            }
            postSaveSummaryVisible = false
        }

        function showPostSaveSummary(statusText) {
            const orderExperience = document.getElementById('orderExperience')
            const postSaveSummary = document.getElementById('postSaveSummary')
            const statusEl = document.getElementById('postSaveStatusText')
            if (orderExperience) orderExperience.classList.add('hidden')
            if (postSaveSummary) {
                postSaveSummary.classList.remove('hidden')
                postSaveSummary.classList.add('flex')
            }
            if (statusEl) statusEl.textContent = normalizeStatus(statusText) || 'Waiting for Approval'
            postSaveSummaryVisible = true
        }

        function updateStatusBanner(status) {
            const meta = getStatusMeta(status)
            const section = document.getElementById('statusBannerSection')
            const banner = document.getElementById('statusBanner')
            const iconWrap = document.getElementById('statusBannerIconWrap')
            const iconPath = document.getElementById('statusBannerIconPath')
            const titleEl = document.getElementById('statusBannerTitle')
            const messageEl = document.getElementById('statusBannerMessage')

            if (!section || !banner || !iconWrap || !iconPath || !titleEl || !messageEl) return

            if (!meta) {
                section.classList.add('hidden')
                return
            }

            const toneClasses = {
                amber: ['bg-amber-50', 'border-amber-200', 'text-amber-900', 'bg-amber-100', 'text-amber-700'],
                green: ['bg-green-50', 'border-green-200', 'text-green-900', 'bg-green-100', 'text-green-700'],
                red: ['bg-red-50', 'border-red-200', 'text-red-900', 'bg-red-100', 'text-red-700'],
                blue: ['bg-blue-50', 'border-blue-200', 'text-blue-900', 'bg-blue-100', 'text-blue-700']
            }
            const [bannerBg, bannerBorder, bannerText, iconBg, iconText] = toneClasses[meta.tone] || toneClasses.amber

            banner.className = `rounded-2xl border px-5 py-4 shadow-sm ${bannerBg} ${bannerBorder} ${bannerText}`
            iconWrap.className = `mt-0.5 w-9 h-9 rounded-full flex items-center justify-center shrink-0 ${iconBg} ${iconText}`
            iconPath.setAttribute('d', meta.iconPath)
            titleEl.textContent = meta.title
            messageEl.textContent = meta.message
            section.classList.remove('hidden')
        }

        // --- Live Timer Logic ---
        // Starts once we have createdDate from host.
        const totalDuration = 24 * 3600; // 24h window in seconds
        let timerIntervalId = 0
        let timerDeadlineMs = 0

        const elHours = document.getElementById('hours');
        const elMinutes = document.getElementById('minutes');
        const elSeconds = document.getElementById('seconds');
        const elProgressBar = document.getElementById('progressBar');
        const elTimeLeftText = document.getElementById('timeLeftText');
        const elTimerStatusMessage = document.getElementById('timerStatusMessage');

        function formatTime(val) {
            return val < 10 ? '0' + val : val;
        }

        function renderTimer(secondsRemaining) {
            const safeSeconds = Math.max(0, secondsRemaining)
            const h = Math.floor(safeSeconds / 3600);
            const m = Math.floor((safeSeconds % 3600) / 60);
            const s = Math.floor(safeSeconds % 60);

            elHours.textContent = formatTime(h);
            elMinutes.textContent = formatTime(m);
            elSeconds.textContent = formatTime(s);
            elTimeLeftText.textContent = `${formatTime(h)}:${formatTime(m)}:${formatTime(s)}`;
            elProgressBar.style.width = `${(safeSeconds / totalDuration) * 100}%`;

            if (elTimerStatusMessage) {
                if (!bypassTimeWindow && safeSeconds <= 0) {
                    elTimerStatusMessage.textContent = 'The 24-hour editing window has expired.'
                    elTimerStatusMessage.classList.remove('hidden')
                } else {
                    elTimerStatusMessage.textContent = ''
                    elTimerStatusMessage.classList.add('hidden')
                }
            }
        }

        function stopTimer() {
            if (timerIntervalId) {
                clearInterval(timerIntervalId)
                timerIntervalId = 0
            }
        }

        function tickTimer() {
            const secondsRemaining = timerDeadlineMs
                ? Math.max(0, Math.floor((timerDeadlineMs - Date.now()) / 1000))
                : 0

            renderTimer(secondsRemaining)

            const nextLockedByTimer = !bypassTimeWindow && !!timerDeadlineMs && secondsRemaining <= 0
            if (nextLockedByTimer !== lockedByTimer) {
                lockedByTimer = nextLockedByTimer
                syncEditingLockState()
            }

            if (secondsRemaining <= 0) {
                stopTimer()
            }
        }

        function startTimer(createdDateStr, shouldBypassTimeWindow = false) {
            stopTimer()
            bypassTimeWindow = !!shouldBypassTimeWindow

            const created = createdDateStr ? new Date(createdDateStr) : null
            if (!created || Number.isNaN(created.getTime())) {
                timerDeadlineMs = 0
                lockedByTimer = false
                renderTimer(0)
                syncEditingLockState()
                return
            }

            timerDeadlineMs = created.getTime() + (24 * 3600 * 1000)
            tickTimer()
            if (!lockedByTimer) {
                timerIntervalId = window.setInterval(tickTimer, 1000)
            }
        }

        function setOrderMetaFromState(state) {
            const order = state?.order || {}
            const contact = state?.contact || {}
            const shipping = state?.shipping || {}
            const permissions = state?.permissions || {}
            const normalizedStatus = normalizeStatus(order?.status) || 'Pending'
            log('setOrderMetaFromState', {
                orderNumber: order?.number,
                status: normalizedStatus,
                itemCount: Array.isArray(state?.items) ? state.items.length : 0,
                isAdminMode: !!permissions?.isAdminMode,
                editingAllowed: permissions?.editingAllowed
            })

            const orderNumEl = document.getElementById('orderNumber')
            if (orderNumEl) orderNumEl.textContent = order?.number ? `#${order.number}` : '#—'

            const statusEl = document.getElementById('orderStatusText')
            if (statusEl) statusEl.textContent = normalizedStatus || '—'

            const nameEl = document.getElementById('contactName')
            if (nameEl) nameEl.textContent = contact?.name ? String(contact.name) : '—'

            const emailEl = document.getElementById('contactEmail')
            if (emailEl) emailEl.textContent = contact?.email ? String(contact.email) : '—'

            const phoneEl = document.getElementById('contactPhone')
            if (phoneEl) phoneEl.textContent = contact?.phone ? String(contact.phone) : '—'

            const addrEl = document.getElementById('shippingAddress')
            if (addrEl) addrEl.textContent = shipping?.address ? String(shipping.address) : '—'

            const createdDate = order?.createdDate || ''
            hostInit.isAdminMode = !!permissions?.isAdminMode
            startTimer(createdDate, !!permissions?.bypassTimeWindow)
            updateStatusBanner(normalizedStatus)

            lockedByHost = permissions.editingAllowed === false
            syncEditingLockState()
        }

        function renderItemsTable(state) {
            const tbody = document.getElementById('itemsTbody')
            if (!tbody) return
            tbody.innerHTML = ''

            const items = Array.isArray(state?.items) ? state.items : []
            log('renderItemsTable', { itemCount: items.length })
            items.forEach((it) => {
                const mergedItem = buildMergedItem(it)
                const row = document.createElement('tr')
                row.className = 'hover:bg-slate-50 transition-colors cursor-pointer group'
                row.dataset.rowKey = it.rowKey || ''

                const imgUrl = mergedItem.image || ''
                const productName = mergedItem.productName || ''
                const size = mergedItem.size || ''
                const color = mergedItem.colorLabel || mergedItem.color || ''
                const colorHex = mergedItem.colorHex || ''
                const nameNumber = mergedItem.nameNumber || ''
                const dirty = isItemChanged(mergedItem)

                row.innerHTML = `
                    <td class="py-3 px-6">
                        <div class="relative w-16 h-16 bg-slate-100 rounded mx-auto overflow-hidden border border-slate-200">
                            ${dirty ? `<span class="absolute top-1 right-1 z-10 bg-amber-500 text-white text-[10px] font-bold px-1.5 py-0.5 rounded-full shadow-sm">Changed</span>` : ''}
                            ${imgUrl ? `<img src="${imgUrl}" alt="" class="w-full h-full object-cover opacity-90" onerror="this.style.display='none'">` : ''}
                        </div>
                    </td>
                    <td class="py-4 px-6 text-slate-800 border-l border-slate-200">${escapeHtml(productName)}</td>
                    <td class="py-4 px-6 text-slate-800 border-l border-slate-200">${escapeHtml(size)}</td>
                    <td class="py-4 px-6 text-slate-800 border-l border-slate-200">
                        <div class="flex items-center justify-center gap-2">
                            ${colorHex ? `<span class="inline-block w-4 h-4 rounded-full border border-slate-300 shadow-sm" style="background:${escapeHtml(colorHex)}"></span>` : ''}
                            <span>${escapeHtml(color)}</span>
                        </div>
                    </td>
                    <td class="py-4 px-6 text-slate-800 border-l border-slate-200">${escapeHtml(nameNumber)}</td>
                `

                row.addEventListener('click', () => {
                    log('row click', { rowKey: it.rowKey, lockedEditing, isAdminMode: hostInit.isAdminMode })
                    openEditModal(it)
                })

                tbody.appendChild(row)
            })
        }

        function escapeHtml(s) {
            return String(s || '')
                .replaceAll('&', '&amp;')
                .replaceAll('<', '&lt;')
                .replaceAll('>', '&gt;')
                .replaceAll('"', '&quot;')
                .replaceAll("'", '&#039;')
        }

        // --- Modal Logic ---
        const editModal = document.getElementById('editModal');
        const editModalContent = document.getElementById('editModalContent');
        const closeModalBtn = document.getElementById('closeModalBtn');
        const cancelModalBtn = document.getElementById('cancelModalBtn');
        const saveModalBtn = document.getElementById('saveModalBtn');
        const resetModalBtn = document.getElementById('resetModalBtn');
        
        const modalImg = document.getElementById('modalImg');
        const modalImgContainer = document.getElementById('modalImgContainer');
        const modalTitle = document.getElementById('modalTitle');
        const modalSize = document.getElementById('modalSize');
        const modalColorGroup = document.getElementById('modalColorGroup');
        const modalColor = document.getElementById('modalColor');
        const modalColorSwatch = document.getElementById('modalColorSwatch');
        const modalNameNumber = document.getElementById('modalNameNumber');
        const modalNameNumberGroup = modalNameNumber.parentElement;
        const modalChangesPanel = document.getElementById('modalChangesPanel');
        const modalChangesList = document.getElementById('modalChangesList');
        
        let currentRow = null;
        let originalSize = '';
        let originalColor = '';
        let originalColorHex = '';
        let originalImage = '';
        let originalNameNum = '';

        const fallbackSizeOptions = ['Youth-XS', 'Youth-Small', 'Youth-Medium', 'Youth-Large', 'GC Y L/XL', 'Adult-S', 'Adult-M', 'Adult-L', 'Adult-XL'];

        function makeDiffRow(label, fromValue, toValue, { fromSwatch = '', toSwatch = '' } = {}) {
            const row = document.createElement('div')
            row.className = 'grid grid-cols-[96px_1fr_auto_1fr] items-center gap-2 rounded-lg bg-white/80 border border-amber-100 px-3 py-2'

            const fromChip = `
                <div class="min-w-0 inline-flex items-center gap-2 rounded-lg border border-slate-200 bg-slate-50 px-2.5 py-2 text-sm text-slate-700">
                    ${fromSwatch ? `<span class="inline-block w-3.5 h-3.5 rounded-full border border-slate-300 shrink-0" style="background:${escapeHtml(fromSwatch)}"></span>` : ''}
                    <span class="truncate">${escapeHtml(fromValue || 'Empty')}</span>
                </div>
            `
            const toChip = `
                <div class="min-w-0 inline-flex items-center gap-2 rounded-lg border border-amber-200 bg-amber-100/70 px-2.5 py-2 text-sm font-medium text-amber-900">
                    ${toSwatch ? `<span class="inline-block w-3.5 h-3.5 rounded-full border border-amber-300 shrink-0" style="background:${escapeHtml(toSwatch)}"></span>` : ''}
                    <span class="truncate">${escapeHtml(toValue || 'Empty')}</span>
                </div>
            `

            row.innerHTML = `
                <span class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">${escapeHtml(label)}</span>
                ${fromChip}
                <span class="text-amber-500 flex items-center justify-center">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
                </span>
                ${toChip}
            `
            return row
        }

        function renderModalChanges(item, mergedItem) {
            if (!modalChangesPanel || !modalChangesList) return

            const originalSizeValue = item?.originalSize || ''
            const originalColorValue = item?.originalColorLabel || item?.originalColor || ''
            const originalColorSwatch = item?.originalColorHex || ''
            const originalNameNumberValue = item?.originalNameNumber || ''

            const currentSizeValue = mergedItem?.size || ''
            const currentColorValue = mergedItem?.colorLabel || mergedItem?.color || ''
            const currentColorSwatch = mergedItem?.colorHex || ''
            const currentNameNumberValue = mergedItem?.nameNumber || ''

            const entries = []

            if (String(originalSizeValue) !== String(currentSizeValue)) {
                entries.push(makeDiffRow('Size', originalSizeValue, currentSizeValue))
            }

            if (
                String(originalColorValue) !== String(currentColorValue) ||
                String(originalColorSwatch) !== String(currentColorSwatch)
            ) {
                entries.push(makeDiffRow('Color', originalColorValue, currentColorValue, {
                    fromSwatch: originalColorSwatch,
                    toSwatch: currentColorSwatch
                }))
            }

            if (String(originalNameNumberValue) !== String(currentNameNumberValue)) {
                entries.push(makeDiffRow('Name / Number', originalNameNumberValue, currentNameNumberValue))
            }

            modalChangesList.innerHTML = ''
            if (!entries.length) {
                modalChangesPanel.classList.add('hidden')
                return
            }

            entries.forEach(entry => modalChangesList.appendChild(entry))
            modalChangesPanel.classList.remove('hidden')
        }

        function applyModalReadOnlyState(readOnly) {
            modalSize.disabled = readOnly
            modalColor.disabled = readOnly
            modalNameNumber.disabled = readOnly
            resetModalBtn.classList.toggle('hidden', readOnly)
            saveModalBtn.textContent = readOnly ? 'Close' : 'Save'
            saveModalBtn.classList.toggle('bg-brand-600', !readOnly)
            saveModalBtn.classList.toggle('hover:bg-brand-700', !readOnly)
            saveModalBtn.classList.toggle('text-white', !readOnly)
            saveModalBtn.classList.toggle('bg-slate-900', readOnly)
            saveModalBtn.classList.toggle('hover:bg-slate-800', readOnly)
            saveModalBtn.classList.toggle('text-white', readOnly)
        }

        function ensureOption(options, value, label = value) {
            const normalizedValue = String(value || '')
            if (!normalizedValue) return options
            const exists = options.some(option => String(option?.value || '').toLowerCase() === normalizedValue.toLowerCase())
            if (exists) return options
            return [{ value: normalizedValue, label: label || normalizedValue }, ...options]
        }

        function setModalColorSwatch(colorHex) {
            if (!modalColorSwatch) return
            if (colorHex) {
                modalColorSwatch.style.backgroundColor = colorHex
                modalColorSwatch.classList.remove('hidden')
            } else {
                modalColorSwatch.style.backgroundColor = 'transparent'
                modalColorSwatch.classList.add('hidden')
            }
        }

        function populateSizeDropdown(item) {
            modalSize.innerHTML = ''

            const actualOptions = Array.isArray(item?.optionSets?.sizes) ? item.optionSets.sizes : []
            const fallbackOptions = fallbackSizeOptions.map(value => ({ value, label: value }))
            const merged = ensureOption(actualOptions.length ? actualOptions : fallbackOptions, item.size, item.size)

            merged.forEach(optionData => {
                if (!optionData?.value) return
                const option = document.createElement('option')
                option.value = optionData.value
                option.textContent = optionData.label || optionData.value
                modalSize.appendChild(option)
            })

            modalSize.value = item.size || ''
        }

        function populateColorDropdown(item) {
            const actualColors = Array.isArray(item?.optionSets?.colors) ? item.optionSets.colors : []
            const merged = ensureOption(actualColors, item.color, item.colorLabel || item.color)

            if (!merged.length || !merged[0]?.value) {
                modalColorGroup.classList.add('hidden')
                modalColor.innerHTML = ''
                setModalColorSwatch('')
                return
            }

            modalColorGroup.classList.remove('hidden')
            modalColor.innerHTML = ''

            merged.forEach(optionData => {
                if (!optionData?.value) return
                const option = document.createElement('option')
                option.value = optionData.value
                option.textContent = optionData.label || optionData.value
                option.dataset.color = optionData.color || ''
                option.dataset.image = optionData.image || ''
                modalColor.appendChild(option)
            })

            modalColor.value = item.color || merged[0].value || ''
            const selectedOption = merged.find(option => option.value === modalColor.value) || merged[0]
            setModalColorSwatch(selectedOption?.color || item.colorHex || '')
        }

        function openEditModal(item) {
            log('openEditModal', { rowKey: item?.rowKey, productName: item?.productName })
            const mergedItem = buildMergedItem(item)
            currentRow = item
            originalSize = mergedItem.size || ''
            originalColor = mergedItem.color || ''
            originalColorHex = mergedItem.colorHex || ''
            originalImage = mergedItem.image || ''
            originalNameNum = mergedItem.nameNumber || ''

            modalTitle.textContent = mergedItem.productName || ''
            modalImg.src = mergedItem.image || ''
            modalImgContainer.className = 'w-24 h-24 bg-slate-100 rounded-lg overflow-hidden border border-slate-200 shadow-sm'

            populateSizeDropdown(mergedItem)
            populateColorDropdown(mergedItem)
            modalNameNumber.value = mergedItem.nameNumber || ''
            renderModalChanges(item, mergedItem)
            applyModalReadOnlyState(lockedEditing)

            if ((item.nameNumber || '').toString().trim()) {
                modalNameNumberGroup.classList.remove('hidden')
            } else {
                modalNameNumberGroup.classList.add('hidden')
            }

            editModal.classList.remove('hidden')
            void editModal.offsetWidth
            editModal.classList.remove('opacity-0')
            editModalContent.classList.remove('scale-95')
        }

        const hideModal = () => {
            editModal.classList.add('opacity-0');
            editModalContent.classList.add('scale-95');
            setTimeout(() => {
                editModal.classList.add('hidden');
                currentRow = null;
            }, 300); // match transition duration
        };

        // Close listeners
        closeModalBtn.addEventListener('click', hideModal);
        cancelModalBtn.addEventListener('click', hideModal);
        
        // Reset listener
        resetModalBtn.addEventListener('click', () => {
            modalSize.value = originalSize;
            if (!modalColorGroup.classList.contains('hidden')) {
                modalColor.value = originalColor;
                setModalColorSwatch(originalColorHex);
                modalImg.src = originalImage || '';
            }
            modalNameNumber.value = originalNameNum;
        });

        modalColor.addEventListener('change', () => {
            const selectedOption = modalColor.options[modalColor.selectedIndex]
            const nextColorHex = selectedOption?.dataset?.color || ''
            const nextImage = selectedOption?.dataset?.image || ''
            setModalColorSwatch(nextColorHex)

            if (nextImage) {
                modalImg.src = nextImage
            } else {
                modalImg.src = currentRow?.image || originalImage || ''
            }

            log('modal color changed', {
                rowKey: currentRow?.rowKey,
                color: modalColor.value,
                colorHex: nextColorHex,
                hasImageOverride: !!nextImage
            })
        })

        // Save listener
        saveModalBtn.addEventListener('click', () => {
            if (lockedEditing) {
                hideModal()
                return
            }
            if (currentRow) {
                const rowKey = currentRow.rowKey || ''
                const previousPatch = draftByRowKey.get(rowKey) || null
                const selectedColorOption = !modalColorGroup.classList.contains('hidden')
                    ? modalColor.options[modalColor.selectedIndex]
                    : null
                const nextValues = {
                    size: modalSize.value || '',
                    color: selectedColorOption ? (modalColor.value || '') : (currentRow.color || ''),
                    colorLabel: selectedColorOption
                        ? ((selectedColorOption.textContent || '').trim() || (modalColor.value || ''))
                        : (currentRow.colorLabel || currentRow.color || ''),
                    colorHex: selectedColorOption ? (selectedColorOption.dataset?.color || '') : (currentRow.colorHex || ''),
                    image: selectedColorOption
                        ? ((selectedColorOption.dataset?.image || '') || currentRow.image || '')
                        : (currentRow.image || ''),
                    nameNumber: modalNameNumberGroup.classList.contains('hidden')
                        ? (currentRow.nameNumber || '')
                        : (modalNameNumber.value || '').trim()
                }
                const baseItem = getBaseItem(rowKey) || currentRow
                const patch = {}
                ;['size', 'color', 'colorLabel', 'colorHex', 'image', 'nameNumber'].forEach(key => {
                    if ((nextValues[key] || '') !== (baseItem?.[key] || '')) {
                        patch[key] = nextValues[key]
                    }
                })

                const nextPatch = Object.keys(patch).length ? patch : null
                const didDraftStateChange =
                    nextPatch
                        ? !areDraftPatchesEqual(previousPatch, nextPatch)
                        : !!previousPatch

                log('modal save clicked', {
                    rowKey,
                    patch,
                    changedKeys: Object.keys(patch),
                    didDraftStateChange
                })
                if (nextPatch) {
                    draftByRowKey.set(rowKey, nextPatch)
                } else {
                    draftByRowKey.delete(rowKey)
                }

                if (didDraftStateChange && uiState && Array.isArray(uiState.items)) {
                    renderItemsTable(uiState)
                }
                if (didDraftStateChange) {
                    refreshSaveButtonState()
                }
            }
            hideModal()
        })
        
        // Close on clicking outside the modal content
        editModal.addEventListener('click', (e) => {
            if (e.target === editModal) {
                hideModal();
            }
        });

        // --- Save Status Modal Logic ---
        const statusModal = document.getElementById('statusModal');
        const statusModalContent = document.getElementById('statusModalContent');
        const loadingState = document.getElementById('loadingState');
        const successState = document.getElementById('successState');
        const closeStatusModalBtn = document.getElementById('closeStatusModalBtn');

        saveButton.addEventListener('click', () => {
            log('save button clicked', {
                disabled: saveButton.hasAttribute('disabled'),
                lockedEditing,
                isAdminMode: hostInit.isAdminMode,
                hasState: !!uiState
            })
            if (saveButton.hasAttribute('disabled')) return
            if (lockedEditing) return
            if (!uiState || !Array.isArray(uiState.items)) return

            const changes = []
            for (const it of uiState.items) {
                const rowKey = it.rowKey || ''
                const patch = draftByRowKey.get(rowKey)
                if (!patch) continue
                changes.push({
                    itemId: it.itemId || '',
                    rowKey: it.rowKey || '',
                    productId: it.productId || '',
                    productName: it.productName || '',
                    size: ('size' in patch) ? patch.size : (it.size || ''),
                    color: ('color' in patch) ? patch.color : (it.color || ''),
                    colorLabel: ('colorLabel' in patch) ? patch.colorLabel : ((it.colorLabel || it.color || '')),
                    colorHex: ('colorHex' in patch) ? patch.colorHex : (it.colorHex || ''),
                    nameNumber: ('nameNumber' in patch) ? patch.nameNumber : (it.nameNumber || ''),
                    image: ('image' in patch) ? patch.image : (it.image || '')
                })
            }

            if (!changes.length) {
                refreshSaveButtonState()
                return
            }
            log('save submitting changes', { changeCount: changes.length, rowKeys: changes.map(x => x.rowKey) })

            // Show status modal (loading)
            statusModal.classList.remove('hidden')
            void statusModal.offsetWidth
            statusModal.classList.remove('opacity-0')
            statusModalContent.classList.remove('scale-95')
            loadingState.classList.remove('hidden')
            successState.classList.add('hidden')

            postToHost({ type: HOST_TYPES.SAVE_SUBMIT, changes })
        })

        const hideStatusModal = () => {
            statusModal.classList.add('opacity-0');
            statusModalContent.classList.add('scale-95');
            setTimeout(() => {
                statusModal.classList.add('hidden');
            }, 300);
        };

        closeStatusModalBtn.addEventListener('click', hideStatusModal);

        // --- Auth Modal Logic ---
        const authModal = document.getElementById('authModal');
        const authSubmitBtn = document.getElementById('authSubmitBtn');
        const authCustomerFields = document.getElementById('authCustomerFields');
        const authAdminFields = document.getElementById('authAdminFields');
        const authOrderNumber = document.getElementById('authOrderNumber');
        const authEmail = document.getElementById('authEmail');
        const authAdminCode = document.getElementById('authAdminCode');
        const authErrorMsg = document.getElementById('authErrorMsg');
        const authErrorText = document.getElementById('authErrorText');
        const authBtnText = document.getElementById('authBtnText');
        const authBtnSpinner = document.getElementById('authBtnSpinner');
        const authHintText = document.getElementById('authHintText');
        const adminLoginToggleBtn = document.getElementById('adminLoginToggleBtn');
        const customerLoginToggleBtn = document.getElementById('customerLoginToggleBtn');

        function setAuthMode(nextMode) {
            authMode = nextMode === 'admin-code' ? 'admin-code' : 'customer'
            authErrorMsg.classList.add('hidden')
            authOrderNumber.classList.remove('border-red-500', 'focus:border-red-500', 'focus:ring-red-500');
            authEmail.classList.remove('border-red-500', 'focus:border-red-500', 'focus:ring-red-500');
            authAdminCode.classList.remove('border-red-500', 'focus:border-red-500', 'focus:ring-red-500');

            if (authMode === 'admin-code') {
                authCustomerFields.classList.add('hidden')
                authAdminFields.classList.remove('hidden')
                adminLoginToggleBtn.classList.add('hidden')
                customerLoginToggleBtn.classList.remove('hidden')
                authBtnText.textContent = 'Login as Admin'
                authHintText.textContent = 'Enter the admin code to bypass customer verification.'
            } else {
                authCustomerFields.classList.remove('hidden')
                authAdminFields.classList.add('hidden')
                adminLoginToggleBtn.classList.remove('hidden')
                customerLoginToggleBtn.classList.add('hidden')
                authBtnText.textContent = 'Submit & Verify'
                authHintText.textContent = 'Hint: Enter your order details to continue'
            }
        }

        adminLoginToggleBtn.addEventListener('click', () => setAuthMode('admin-code'))
        customerLoginToggleBtn.addEventListener('click', () => setAuthMode('customer'))

        authSubmitBtn.addEventListener('click', () => {
            log('verify button clicked')
            if (authSubmitBtn.hasAttribute('disabled')) return;

            authErrorMsg.classList.add('hidden');
            authOrderNumber.classList.remove('border-red-500', 'focus:border-red-500', 'focus:ring-red-500');
            authEmail.classList.remove('border-red-500', 'focus:border-red-500', 'focus:ring-red-500');
            authAdminCode.classList.remove('border-red-500', 'focus:border-red-500', 'focus:ring-red-500');

            if (authMode === 'admin-code') {
                const adminCodeVal = authAdminCode.value.trim();
                log('admin auth form values', {
                    hasAdminCode: !!adminCodeVal,
                    hostOrderId: hostInit.orderId
                })

                if (adminCodeVal === '') {
                    authAdminCode.classList.add('border-red-500', 'focus:border-red-500', 'focus:ring-red-500');
                    return;
                }

                authSubmitBtn.setAttribute('disabled', 'true');
                authSubmitBtn.classList.add('opacity-80', 'cursor-not-allowed');
                authBtnText.classList.add('opacity-0');
                authBtnSpinner.classList.remove('hidden');

                log('sending TW_AUTH_SUBMIT admin-code')
                postToHost({ type: HOST_TYPES.AUTH_SUBMIT, mode: 'admin-code', adminCode: adminCodeVal })
                return
            }

            const orderVal = authOrderNumber.value.trim();
            const emailVal = authEmail.value.trim();
            log('auth form values', {
                orderNumberLength: orderVal.length,
                email: maskEmail(emailVal),
                hostOrderId: hostInit.orderId,
                isAdminMode: hostInit.isAdminMode
            })
            // Basic validation for empty fields
            let hasError = false;
            if(orderVal === '') {
                authOrderNumber.classList.add('border-red-500', 'focus:border-red-500', 'focus:ring-red-500');
                hasError = true;
            }
            if(emailVal === '') {
                authEmail.classList.add('border-red-500', 'focus:border-red-500', 'focus:ring-red-500');
                hasError = true;
            }

            if(hasError) return;

            // 1. Show Loading State
            authSubmitBtn.setAttribute('disabled', 'true');
            authSubmitBtn.classList.add('opacity-80', 'cursor-not-allowed');
            authBtnText.classList.add('opacity-0');
            authBtnSpinner.classList.remove('hidden');

            log('sending TW_AUTH_SUBMIT')
            postToHost({ type: HOST_TYPES.AUTH_SUBMIT, email: emailVal, orderNumber: orderVal })
        });

        // Remove error states when user types again
        authOrderNumber.addEventListener('input', () => {
            authErrorMsg.classList.add('hidden');
            authOrderNumber.classList.remove('border-red-500', 'focus:border-red-500', 'focus:ring-red-500');
        });
        
        authEmail.addEventListener('input', () => {
            authErrorMsg.classList.add('hidden');
            authEmail.classList.remove('border-red-500', 'focus:border-red-500', 'focus:ring-red-500');
        });

        authAdminCode.addEventListener('input', () => {
            authErrorMsg.classList.add('hidden');
            authAdminCode.classList.remove('border-red-500', 'focus:border-red-500', 'focus:ring-red-500');
        });

        // --- Incoming messages from host ---
        window.addEventListener('message', (ev) => {
            const d = ev?.data || {}
            if (!d || typeof d !== 'object') return
            log('<- host', d.type || '(no-type)', d)

            if (d.type === HOST_TYPES.INIT) {
                hostInit = { orderId: d.orderId || '', isAdminMode: !!d.isAdminMode }
                log('received TW_INIT', hostInit)
                // admin mode: no auth modal
                if (hostInit.isAdminMode) {
                    authModal.classList.add('hidden')
                    document.body.classList.remove('overflow-hidden')
                }
                syncEditingLockState()
                return
            }

            if (d.type === HOST_TYPES.SET_STATE) {
                log('received TW_SET_STATE')
                uiState = d.state || null
                baseItemsByRowKey = new Map((uiState?.items || []).map(item => [item.rowKey, { ...item }]))
                if (uiState) {
                    setOrderMetaFromState(uiState)
                    if (!postSaveSummaryVisible) {
                        showOrderExperience()
                        renderItemsTable(uiState)
                    }
                }
                refreshSaveButtonState()

                // hide auth if we now have order number
                if (uiState?.order?.number) {
                    authModal.classList.add('opacity-0')
                    setTimeout(() => {
                        authModal.classList.add('hidden')
                        document.body.classList.remove('overflow-hidden')
                    }, 200)
                }
                return
            }

            if (d.type === HOST_TYPES.AUTH_RESULT) {
                log('received TW_AUTH_RESULT', { ok: !!d.ok, message: d.message || '' })
                // Remove Loading State
                authSubmitBtn.removeAttribute('disabled')
                authSubmitBtn.classList.remove('opacity-80', 'cursor-not-allowed')
                authBtnText.classList.remove('opacity-0')
                authBtnSpinner.classList.add('hidden')

                if (!d.ok) {
                    if (authErrorText && d.message) authErrorText.textContent = String(d.message)
                    authErrorMsg.classList.remove('hidden')
                    if (authMode === 'admin-code') {
                        authAdminCode.classList.add('border-red-500')
                    } else {
                        authOrderNumber.classList.add('border-red-500')
                        authEmail.classList.add('border-red-500')
                    }
                }
                return
            }

            if (d.type === HOST_TYPES.SAVE_RESULT) {
                log('received TW_SAVE_RESULT', { ok: !!d.ok, message: d.message || '', newStatus: d.newStatus || '' })
                if (d.ok) {
                    hideStatusModal()
                    draftByRowKey = new Map()
                    showPostSaveSummary(d.newStatus || 'Waiting for Approval')
                    refreshSaveButtonState()
                } else {
                    // show failure as authError-style banner inside status modal (simple reuse)
                    loadingState.classList.add('hidden')
                    successState.classList.remove('hidden')
                    const p = successState.querySelector('p')
                    if (p) p.textContent = d.message ? String(d.message) : 'Failed to save changes.'
                }
                return
            }

            if (d.type === HOST_TYPES.LOCK_EDITING) {
                log('received TW_LOCK_EDITING', { locked: !!d.locked, reason: d.reason || '' })
                lockedByHost = !!d.locked
                syncEditingLockState()
                return
            }
        })

        // In case the host missed our initial ready, ask for state soon
        setTimeout(() => {
            log('sending TW_REQUEST_STATE fallback')
            postToHost({ type: HOST_TYPES.REQUEST_STATE })
        }, 300)

    </script>
</body>
</html>