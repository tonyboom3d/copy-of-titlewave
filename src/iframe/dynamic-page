                <!-- Success State -->
                <div id="successState" class="hidden flex flex-col items-center justify-center py-4">
                    <div id="statusResultIconWrap" class="w-14 h-14 bg-green-100 text-green-500 rounded-full flex items-center justify-center mb-4">
                        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path id="statusResultIconPath" stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
